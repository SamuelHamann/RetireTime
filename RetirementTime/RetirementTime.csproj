      <EmbeddedResource Update="Resources\BeginnerGuide\BeginnerGuideResources.fr-CA.resx">
        <Generator>PublicResXFileCodeGenerator</Generator>
        <LastGenOutput>BeginnerGuideResources.fr-CA.Designer.cs</LastGenOutput>
      </EmbeddedResource>
      <EmbeddedResource Update="Resources\Landing\LandingResources.resx">
