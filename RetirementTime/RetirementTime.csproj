<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <BlazorDisableThrowNavigationException>true</BlazorDisableThrowNavigationException>
        <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
        <RootNamespace>RetirementTime</RootNamespace>
    </PropertyGroup>

    <ItemGroup>
      <Compile Remove="Models\BeginnerGuide\InvestmentProperties\**" />
      <Compile Remove="Models\BeginnerGuide\OtherAssets\**" />
      <Content Remove="Models\BeginnerGuide\InvestmentProperties\**" />
      <Content Remove="Models\BeginnerGuide\OtherAssets\**" />
      <EmbeddedResource Remove="Models\BeginnerGuide\InvestmentProperties\**" />
      <EmbeddedResource Remove="Models\BeginnerGuide\OtherAssets\**" />
      <None Remove="Models\BeginnerGuide\InvestmentProperties\**" />
      <None Remove="Models\BeginnerGuide\OtherAssets\**" />
    </ItemGroup>

    <ItemGroup>
      <Content Include="..\.dockerignore">
        <Link>.dockerignore</Link>
      </Content>
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\RetirementTime.Infrastructure\RetirementTime.Infrastructure.csproj" />
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="MediatR" Version="14.0.0" />
      <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="10.0.1">
        <PrivateAssets>all</PrivateAssets>
        <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      </PackageReference>
    </ItemGroup>

    <ItemGroup>
      <EmbeddedResource Update="Resources\Auth\AuthResources.resx">
        <Generator>PublicResXFileCodeGenerator</Generator>
        <LastGenOutput>AuthResources.Designer.cs</LastGenOutput>
      </EmbeddedResource>
      <EmbeddedResource Update="Resources\Auth\AuthResources.fr-CA.resx">
        <Generator>PublicResXFileCodeGenerator</Generator>
        <LastGenOutput>AuthResources.fr-CA.Designer.cs</LastGenOutput>
      </EmbeddedResource>
      <EmbeddedResource Update="Resources\BeginnerGuide\BeginnerGuideResources.resx">
