      </EmbeddedResource>
      <EmbeddedResource Update="Resources\Dashboard\DashboardResources.resx">
        <Generator>PublicResXFileCodeGenerator</Generator>
        <LastGenOutput>DashboardResources.Designer.cs</LastGenOutput>
      </EmbeddedResource>
      <EmbeddedResource Update="Resources\Dashboard\DashboardResources.fr-CA.resx">
        <Generator>PublicResXFileCodeGenerator</Generator>
        <LastGenOutput>DashboardResources.fr-CA.Designer.cs</LastGenOutput>
      </EmbeddedResource>
    </ItemGroup>

    <ItemGroup>
      <Compile Update="Resources\Auth\AuthResources.Designer.cs">
        <DesignTime>True</DesignTime>
        <AutoGen>True</AutoGen>
        <DependentUpon>AuthResources.resx</DependentUpon>
      </Compile>
