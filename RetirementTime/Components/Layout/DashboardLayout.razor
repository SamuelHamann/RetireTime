@inherits LayoutComponentBase
@using RetirementTime.Components.Pages.Dashboard
@using RetirementTime.Components.Pages.Introduction
@using RetirementTime.Components.Shared

<HeadContent>
    <link rel="stylesheet" href="css/dashboard.css" />
</HeadContent>

<AuthorizeView>
    <Authorized>
        <div class="dashboard-shell">
            <DashboardSidebar HasCompletedIntro="@HasCompletedIntro" />

            <div class="dashboard-body">
                <IntroTopbar ActiveSection="dashboard" Initials="@_initials" />
                @Body
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

