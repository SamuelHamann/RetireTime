@using RetirementTime.Resources.Common

<header class="topnav">
    <!-- Right: nav links + actions -->
    <div class="topnav-right">
        <nav class="topnav-links">
            <a href="/onboarding" class="topnav-link @(ActiveSection == "onboarding" ? "topnav-link--active" : "")">
                @CommonLocalizer["Nav_Onboarding"]
            </a>
            @if (HasCompletedIntro)
            {
                <a href="/home" class="topnav-link @(ActiveSection == "dashboard" ? "topnav-link--active" : "")">
                    @CommonLocalizer["Nav_Dashboard"]
                </a>
            }
            else
            {
                <span class="topnav-link topnav-link--disabled" title="Complete onboarding to access dashboard">
                    @CommonLocalizer["Nav_Dashboard"]
                </span>
            }
        </nav>

        <div class="topnav-actions">
            <button class="topnav-icon-btn" title="Help" aria-label="Help">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                    <line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
            </button>
            <div class="topnav-avatar">
                @Initials
            </div>
        </div>
    </div>
</header>
