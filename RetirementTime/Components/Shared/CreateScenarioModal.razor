@using RetirementTime.Application.Features.Dashboard.Common

<div class="modal-backdrop" @onclick="OnCancel">
    <div class="modal-content" @onclick:stopPropagation="true">
        <div class="modal-header">
            <h2 class="modal-title">Create New Scenario</h2>
            <button class="modal-close" @onclick="OnCancel">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>

        <div class="modal-body">
            <EditForm Model="@_model" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label for="scenarioName" class="form-label">Scenario Name</label>
                    <InputText id="scenarioName" @bind-Value="_model.ScenarioName" class="form-input" placeholder="e.g., Conservative Retirement" />
                    <ValidationMessage For="@(() => _model.ScenarioName)" class="form-error" />
                </div>

                <div class="form-group">
                    <label for="cloneFrom" class="form-label">Clone From (Optional)</label>
                    <InputSelect id="cloneFrom" @bind-Value="_model.CloneFromScenarioId" class="form-select">
                        <option value="">-- Don't Clone --</option>
                        @foreach (var scenario in ExistingScenarios)
                        {
                            <option value="@scenario.ScenarioId">@scenario.ScenarioName</option>
                        }
                    </InputSelect>
                </div>

                <div class="modal-actions">
                    <button type="button" class="btn-cancel" @onclick="OnCancel">Cancel</button>
                    <button type="submit" class="btn-submit" disabled="@_isSubmitting">
                        @if (_isSubmitting)
                        {
                            <span>Creating...</span>
                        }
                        else
                        {
                            <span>Create Scenario</span>
                        }
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>
