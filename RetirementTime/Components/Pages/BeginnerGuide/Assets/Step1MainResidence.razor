@using RetirementTime.Resources.BeginnerGuide
@using RetirementTime.Components.Shared
@using RetirementTime.Models.BeginnerGuide.Assets
@inject IStringLocalizer<BeginnerGuideResources> Localizer

<!-- Step 1: Main Residence -->
<div class="question-section">
    <h4 class="question-title">@Localizer["Assets_Step1_Question"]</h4>
    
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @_errorMessage
        </div>
    }
    
    <YesNoToggle @bind-Value="OwnsMainResidence" 
                YesLabel="@Localizer["Assets_Step1_Yes"]" 
                NoLabel="@Localizer["Assets_Step1_No"]" />
    
    @if (OwnsMainResidence)
    {
        <div class="property-form">
            <div class="form-grid">
                <div class="form-group">
                    <label for="purchasePrice" class="form-label">@Localizer["Assets_Step1_PurchasePrice"]</label>
                    <div class="input-with-icon">
                        <span class="input-icon">$</span>
                        <input type="number" 
                               id="purchasePrice" 
                               class="form-input" 
                               @bind="PropertyData.PurchasePrice"
                               min="0"
                               required />
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="monthlyMortgage" class="form-label">@Localizer["Assets_Step1_MonthlyMortgage"]</label>
                    <div class="input-with-icon">
                        <span class="input-icon">$</span>
                        <input type="number" 
                               id="monthlyMortgage" 
                               class="form-input" 
                               @bind="PropertyData.MonthlyMortgagePayments"
                               min="0"
                               required />
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="mortgageLeft" class="form-label">@Localizer["Assets_Step1_MortgageLeft"]</label>
                    <div class="input-with-icon">
                        <span class="input-icon">$</span>
                        <input type="number" 
                               id="mortgageLeft" 
                               class="form-input" 
                               @bind="PropertyData.MortgageLeft"
                               min="0"
                               required />
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="yearlyInsurance" class="form-label">@Localizer["Assets_Step1_YearlyInsurance"]</label>
                    <div class="input-with-icon">
                        <span class="input-icon">$</span>
                        <input type="number" 
                               id="yearlyInsurance" 
                               class="form-input" 
                               @bind="PropertyData.YearlyInsurance"
                               min="0"
                               required />
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="electricityCosts" class="form-label">
                        @Localizer["Assets_Step1_ElectricityCosts"]
                        <span class="optional-label">@Localizer["Assets_Step1_Optional"]</span>
                    </label>
                    <div class="input-with-icon">
                        <span class="input-icon">$</span>
                        <input type="number" 
                               id="electricityCosts" 
                               class="form-input" 
                               @bind="PropertyData.MonthlyElectricityCosts"
                               min="0" />
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="mortgageDuration" class="form-label">@Localizer["Assets_Step1_MortgageDuration"]</label>
                    <input type="number" 
                           id="mortgageDuration" 
                           class="form-input" 
                           @bind="PropertyData.MortgageDuration"
                           min="1"
                           required />
                </div>
                
                <div class="form-group">
                    <label for="mortgageStartDate" class="form-label">@Localizer["Assets_Step1_MortgageStartDate"]</label>
                    <input type="date" 
                           id="mortgageStartDate" 
                           class="form-input" 
                           @bind="PropertyData.MortgageStartDate"
                           max="@DateTime.Today.ToString("yyyy-MM-dd")"
                           required />
                </div>
                
                <div class="form-group">
                    <label for="estimatedValue" class="form-label">
                        @Localizer["Assets_Step1_EstimatedValue"]
                        <span class="optional-label">@Localizer["Assets_Step1_Optional"]</span>
                    </label>
                    <div class="input-with-icon">
                        <span class="input-icon">$</span>
                        <input type="number" 
                               id="estimatedValue" 
                               class="form-input" 
                               @bind="PropertyData.EstimatedValue"
                               min="0" />
                    </div>
                </div>
            </div>
            
            <div class="form-actions">
                <button type="button" class="btn-save" @onclick="HandleSave" disabled="@_isSaving">
                    @if (_isSaving)
                    {
                        <span>Saving...</span>
                    }
                    else
                    {
                        @Localizer["Assets_Step1_SaveContinue"]
                    }
                </button>
            </div>
        </div>
    }
    else
    {
        <!-- Next button when No is selected -->
        <div class="form-actions" style="margin-top: 2rem;">
            <button type="button" class="btn-next" @onclick="HandleNext">
                @Localizer["Assets_Step1_Next"]
            </button>
        </div>
    }
</div>


