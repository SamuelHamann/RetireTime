@using RetirementTime.Resources.BeginnerGuide
@using RetirementTime.Models.BeginnerGuide.Benefits
@using RetirementTime.Components.Shared

@inject IStringLocalizer<BeginnerGuideResources> Localizer

<div class="step-container">
    <div class="step-header">
        <h2>@Localizer["Benefits_Step2_Title"]</h2>
        <p class="step-description">@Localizer["Benefits_Step2_Description"]</p>
    </div>

    @if (_isLoading)
    {
        <div class="loading-container">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">@Localizer["Common_Loading"]</span>
            </div>
            <p class="loading-message">@Localizer["Benefits_Step2_LoadingMessage"]</p>
        </div>
    }
    else
    {
        <EditForm Model="@_governmentPension" OnValidSubmit="@HandleSaveAndContinue">
            <DataAnnotationsValidator />

            <div class="card mb-4">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">
                            @Localizer["Benefits_Step2_YearsWorked"]
                            <span class="text-danger">@Localizer["Benefits_Step2_Required"]</span>
                        </label>
                        <InputNumber @bind-Value="_governmentPension.YearsWorked"
                                     class="form-control"
                                     min="0"
                                     max="100" />
                        <small class="form-text text-muted">@Localizer["Benefits_Step2_YearsWorkedHint"]</small>
                        <ValidationMessage For="@(() => _governmentPension.YearsWorked)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">@Localizer["Benefits_Step2_SpecializedPensionQuestion"]</label>
                        <p class="text-muted small mb-2">@Localizer["Benefits_Step2_SpecializedPensionExamples"]</p>
                        <YesNoToggle @bind-Value="@_governmentPension.HasSpecializedPublicSectorPension"
                                     YesLabel="@Localizer["Benefits_Step2_Yes"]"
                                     NoLabel="@Localizer["Benefits_Step2_No"]" />
                    </div>

                    @if (_governmentPension.HasSpecializedPublicSectorPension)
                    {
                        <div class="mb-3">
                            <label class="form-label">
                                @Localizer["Benefits_Step2_SpecializedPensionName"]
                            </label>
                            <InputText @bind-Value="_governmentPension.SpecializedPensionName"
                                       class="form-control"
                                       placeholder="@Localizer["Benefits_Step2_SpecializedPensionNamePlaceholder"]" />
                            <ValidationMessage For="@(() => _governmentPension.SpecializedPensionName)" />
                        </div>
                    }
                </div>
            </div>

            <div class="form-actions">
                <button type="button" class="btn btn-outline-secondary" @onclick="HandlePrevious">
                    <i class="bi bi-arrow-left"></i> @Localizer["Benefits_Step2_PreviousStep"]
                </button>

                <button type="submit" class="btn btn-primary" disabled="@_isSaving">
                    @if (_isSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        @Localizer["Benefits_Step2_Saving"]
                    }
                    else
                    {
                        @Localizer["Benefits_Step2_SaveContinue"]
                    }
                </button>
            </div>
        </EditForm>
    }
</div>
