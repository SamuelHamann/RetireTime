@using RetirementTime.Resources.BeginnerGuide
@inject IStringLocalizer<BeginnerGuideResources> Localizer
@rendermode InteractiveServer

<div class="benefits-section-container">
    <!-- Sub-breadcrumb with dots -->
    <nav class="sub-breadcrumb" aria-label="Benefits steps">
        <ol class="dot-navigation">
            @for (int i = 0; i < 3; i++)
            {
                var stepIndex = i;
                <li class="dot-item @GetDotActiveClass(stepIndex)">
                    <button type="button" 
                            class="dot-button" 
                            @onclick="@(() => SetCurrentStep(stepIndex))"
                            aria-label="Step @(stepIndex + 1)">
                    </button>
                </li>
            }
        </ol>
    </nav>

    <h3>@Localizer["Benefits_Title"]</h3>

    <!-- Content based on current step -->
    <div class="step-content mt-4">
        <p>@string.Format(Localizer["Benefits_StepOf"], (_currentStep + 1), 3)</p>

        @if (_isLoading)
        {
            <div class="text-center py-4">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">@Localizer["Common_Loading"]</span>
                </div>
            </div>
        }
        else if (_currentStep == 0)
        {
            <Step1Pension 
                UserId="_userId"
                HasPensions="_hasPensions"
                HasPensionsChanged="EventCallback.Factory.Create<bool>(this, v => _hasPensions = v)"
                Pensions="_pensions"
                PensionTypes="_pensionTypes"
                OnPrevious="EventCallback.Factory.Create(this, GoToPreviousSection)"
                OnNext="EventCallback.Factory.Create(this, GoToNextStep)" />
        }
        else if (_currentStep == 1)
        {
            <Step2GovernmentPension 
                UserId="_userId"
                GovernmentPension="_governmentPension"
                OnPrevious="EventCallback.Factory.Create(this, GoToPreviousStep)"
                OnNext="EventCallback.Factory.Create(this, GoToNextStep)" />
        }
        else if (_currentStep == 2)
        {
            <Step3OtherRecurringGains
                UserId="_userId"
                HasOtherRecurringGains="_hasOtherRecurringGains"
                HasOtherRecurringGainsChanged="EventCallback.Factory.Create<bool>(this, v => _hasOtherRecurringGains = v)"
                OtherRecurringGains="_otherRecurringGains"
                OnPrevious="EventCallback.Factory.Create(this, GoToPreviousStep)"
                OnNext="EventCallback.Factory.Create(this, GoToNextSection)" />
        }
    </div>
</div>
