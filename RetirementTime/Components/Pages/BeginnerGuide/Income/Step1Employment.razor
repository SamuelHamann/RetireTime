@using RetirementTime.Resources.BeginnerGuide
@using RetirementTime.Components.Shared
@using RetirementTime.Models.BeginnerGuide.Income
@inject IStringLocalizer<BeginnerGuideResources> Localizer

<div class="employment-step">
    <h3>@Localizer["Income_Step1_Title"]</h3>
    <p class="mb-1">@Localizer["Income_Step1_Description"]</p>
    <p class="text-muted small mb-4">@Localizer["Income_Step1_SelfEmploymentNote"]</p>

    @if (_isLoading)
    {
        <div class="loading-container text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">@Localizer["Common_Loading"]</span>
            </div>
            <p class="mt-3 text-muted">@Localizer["Common_LoadingMessage"]</p>
        </div>
    }
    else
    {
        <EditForm Model="@_formModel" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <!-- Yes/No Toggle -->
            <div class="form-group mb-4">
                <label class="form-label fw-bold">@Localizer["Income_Step1_Question"]</label>
                <YesNoToggle @bind-Value="_formModel.IsEmployed"
                             YesLabel="@Localizer["Income_Step1_Yes"]"
                             NoLabel="@Localizer["Income_Step1_No"]" />
            </div>

            @if (_formModel.IsEmployed)
            {
                <div class="employments-list mb-4">
                    @if (_formModel.Employments.Count == 0)
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> @Localizer["Income_Step1_NoEmploymentsAdded"]
                        </div>
                    }
                    else
                    {
                        @for (int i = 0; i < _formModel.Employments.Count; i++)
                        {
                            var index = i;
                            var employment = _formModel.Employments[index];

                            <div class="card mb-4">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <h5 class="card-title mb-0">@Localizer["Income_Step1_EmploymentTitle", (index + 1)]</h5>
                                        <button type="button" class="btn btn-sm btn-danger" @onclick="() => RemoveEmployment(index)">
                                            <i class="bi bi-trash"></i> @Localizer["Income_Step1_Remove"]
                                        </button>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label fw-semibold">@Localizer["Income_Step1_EmployerName"] <span class="text-danger">@Localizer["Income_Step1_Required"]</span></label>
                                            <InputText class="form-control" @bind-Value="employment.EmployerName" placeholder="@Localizer["Income_Step1_EmployerNamePlaceholder"]" />
                                            <ValidationMessage For="@(() => employment.EmployerName)" />
                                        </div>

                                        <div class="col-md-6 mb-3">
                                            <label class="form-label fw-semibold">@Localizer["Income_Step1_AnnualSalary"] <span class="text-danger">@Localizer["Income_Step1_Required"]</span></label>
                                            <div class="input-group">
                                                <span class="input-group-text">$</span>
                                                <InputNumber class="form-control" @bind-Value="employment.AnnualSalary" placeholder="0.00" />
                                            </div>
                                            <ValidationMessage For="@(() => employment.AnnualSalary)" />
                                        </div>

                                        <div class="col-12 mb-3">
                                            <label class="form-label fw-semibold">@Localizer["Income_Step1_AverageWageIncrease"] <span class="text-danger">@Localizer["Income_Step1_Required"]</span></label>
                                            <p class="text-muted small mb-1">@Localizer["Income_Step1_AverageWageIncreaseHint"]</p>
                                            <div class="input-group" style="max-width: 200px;">
                                                <InputNumber class="form-control" @bind-Value="employment.AverageAnnualWageIncrease" placeholder="2.00" />
                                                <span class="input-group-text">%</span>
                                            </div>
                                            <ValidationMessage For="@(() => employment.AverageAnnualWageIncrease)" />
                                        </div>
                                    </div>

                                    <!-- Additional Compensations -->
                                    <hr />
                                    <h6 class="mb-3">@Localizer["Income_Step1_AdditionalCompensations"]</h6>

                                    @if (employment.AdditionalCompensations.Count == 0)
                                    {
                                        <p class="text-muted small">@Localizer["Income_Step1_NoAdditionalCompensations"]</p>
                                    }
                                    else
                                    {
                                        @for (int j = 0; j < employment.AdditionalCompensations.Count; j++)
                                        {
                                            var compIndex = j;
                                            var comp = employment.AdditionalCompensations[compIndex];

                                            <div class="row align-items-end mb-2 g-2">
                                                <div class="col-md-5">
                                                    <label class="form-label small">@Localizer["Income_Step1_CompensationName"] <span class="text-danger">@Localizer["Income_Step1_Required"]</span></label>
                                                    <InputText class="form-control form-control-sm" @bind-Value="comp.Name" placeholder="@Localizer["Income_Step1_CompensationNamePlaceholder"]" />
                                                    <ValidationMessage For="@(() => comp.Name)" />
                                                </div>
                                                <div class="col-md-5">
                                                    <label class="form-label small">@Localizer["Income_Step1_CompensationAmount"] <span class="text-danger">@Localizer["Income_Step1_Required"]</span></label>
                                                    <div class="input-group input-group-sm">
                                                        <span class="input-group-text">$</span>
                                                        <InputNumber class="form-control" @bind-Value="comp.Amount" placeholder="0.00" />
                                                    </div>
                                                    <ValidationMessage For="@(() => comp.Amount)" />
                                                </div>
                                                <div class="col-md-2">
                                                    <button type="button" class="btn btn-sm btn-outline-danger w-100"
                                                            @onclick="() => RemoveCompensation(index, compIndex)">
                                                        <i class="bi bi-x-circle"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    }

                                    <button type="button" class="btn btn-sm btn-outline-secondary mt-2"
                                            @onclick="() => AddCompensation(index)">
                                        <i class="bi bi-plus-circle"></i> @Localizer["Income_Step1_AddCompensation"]
                                    </button>
                                </div>
                            </div>
                        }
                    }

                    <button type="button" class="btn btn-outline-primary" @onclick="AddEmployment">
                        <i class="bi bi-plus-circle"></i> @Localizer["Income_Step1_AddEmployment"]
                    </button>
                </div>
            }

            <!-- Error Message -->
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-triangle"></i> @_errorMessage
                </div>
            }

            <!-- Action Buttons -->
            <div class="d-flex justify-content-between mt-4">
                <button type="button" class="btn btn-secondary" @onclick="GoBack">
                    <i class="bi bi-arrow-left"></i> @Localizer["Income_Step1_PreviousStep"]
                </button>
                <button type="submit" class="btn btn-primary" disabled="@_isSubmitting">
                    @if (_isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    }
                    @Localizer["Income_Step1_SaveContinue"] <i class="bi bi-arrow-right"></i>
                </button>
            </div>
        </EditForm>
    }
</div>

