@using RetirementTime.Resources.BeginnerGuide
@using RetirementTime.Components.Pages.BeginnerGuide.Debts
@using RetirementTime.Services
@inject IStringLocalizer<BeginnerGuideResources> Localizer
@rendermode InteractiveServer

<div class="debts-container">
    <!-- Sub-breadcrumb with dots -->
    <nav class="sub-breadcrumb" aria-label="Debt steps">
        <ol class="dot-navigation">
            <li class="dot-item dot-active">
                <button type="button" class="dot-button" aria-label="Step 1"></button>
            </li>
        </ol>
    </nav>

    <div class="step-content mt-4">
        @if (_isLoading)
        {
            <div class="text-center py-4">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">@Localizer["Debts_Step1_Loading"]</span>
                </div>
            </div>
        }
        else
        {
            <Step1Debts
                UserId="_userId"
                OnPrevious="EventCallback.Factory.Create(this, GoToPreviousSection)"
                OnNext="EventCallback.Factory.Create(this, GoToNextSection)" />
        }
    </div>
</div>

