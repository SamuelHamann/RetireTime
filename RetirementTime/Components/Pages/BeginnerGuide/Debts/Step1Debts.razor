@using RetirementTime.Resources.BeginnerGuide
@using RetirementTime.Components.Shared
@using RetirementTime.Models.BeginnerGuide.Debts
@using RetirementTime.Domain.Entities.BeginnerGuide.Debt
@inject IStringLocalizer<BeginnerGuideResources> Localizer

<div class="debts-step">
    <h3>@Localizer["Debts_Step1_Title"]</h3>
    <p class="mb-4">@Localizer["Debts_Step1_Description"]</p>

    @if (_isLoading)
    {
        <div class="loading-container text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">@Localizer["Debts_Step1_Loading"]</span>
            </div>
            <p class="mt-3 text-muted">@Localizer["Debts_Step1_LoadingMessage"]</p>
        </div>
    }
    else
    {
        <EditForm Model="@_formModel" OnValidSubmit="@(EventCallback.Factory.Create(this, HandleSubmit))">
            <DataAnnotationsValidator />

            <!-- Yes/No Toggle -->
            <div class="form-group mb-4">
                <label class="form-label fw-bold">@Localizer["Debts_Step1_Question"]</label>
                <YesNoToggle @bind-Value="_formModel.HasDebts"
                             YesLabel="@Localizer["Debts_Step1_Yes"]"
                             NoLabel="@Localizer["Debts_Step1_No"]" />
            </div>

            @if (_formModel.HasDebts)
            {
                <!-- Debts List -->
                <div class="debts-list mb-4">
                    @if (_formModel.Debts.Count == 0)
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> @Localizer["Debts_Step1_NoDebtsAdded"]
                        </div>
                    }
                    else
                    {
                        @for (int i = 0; i < _formModel.Debts.Count; i++)
                        {
                            var index = i;
                            var debt = _formModel.Debts[index];

                            <div class="card mb-3">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <h5 class="card-title mb-0">@Localizer["Debts_Step1_DebtTitle", (index + 1)]</h5>
                                        <button type="button" class="btn btn-sm btn-danger" @onclick="() => RemoveDebt(index)">
                                            <i class="bi bi-trash"></i> @Localizer["Debts_Step1_Remove"]
                                        </button>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">@Localizer["Debts_Step1_DebtType"] <span class="text-danger">@Localizer["Debts_Step1_Required"]</span></label>
                                            <InputSelect class="form-select" @bind-Value="debt.Type">
                                                <option value="@BeginnerGuideDebtType.CreditCard">@Localizer["Debts_Step1_Type_CreditCard"]</option>
                                                <option value="@BeginnerGuideDebtType.Car">@Localizer["Debts_Step1_Type_Car"]</option>
                                                <option value="@BeginnerGuideDebtType.PersonalLoan">@Localizer["Debts_Step1_Type_PersonalLoan"]</option>
                                                <option value="@BeginnerGuideDebtType.LineOfCredit">@Localizer["Debts_Step1_Type_LineOfCredit"]</option>
                                                <option value="@BeginnerGuideDebtType.Other">@Localizer["Debts_Step1_Type_Other"]</option>
                                            </InputSelect>
                                            <ValidationMessage For="@(() => debt.Type)" />
                                        </div>

                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">@Localizer["Debts_Step1_Amount"] <span class="text-danger">@Localizer["Debts_Step1_Required"]</span></label>
                                            <div class="input-group">
                                                <span class="input-group-text">$</span>
                                                <InputNumber class="form-control" @bind-Value="debt.Amount" placeholder="0.00" />
                                            </div>
                                            <ValidationMessage For="@(() => debt.Amount)" />
                                        </div>

                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">@Localizer["Debts_Step1_MonthlyPayment"] <span class="text-danger">@Localizer["Debts_Step1_Required"]</span></label>
                                            <div class="input-group">
                                                <span class="input-group-text">$</span>
                                                <InputNumber class="form-control" @bind-Value="debt.MonthlyPayment" placeholder="0.00" />
                                            </div>
                                            <ValidationMessage For="@(() => debt.MonthlyPayment)" />
                                        </div>

                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">@Localizer["Debts_Step1_InterestRate"] <span class="text-danger">@Localizer["Debts_Step1_Required"]</span></label>
                                            <div class="input-group">
                                                <InputNumber class="form-control" @bind-Value="debt.InterestRate" placeholder="0.00" />
                                                <span class="input-group-text">%</span>
                                            </div>
                                            <ValidationMessage For="@(() => debt.InterestRate)" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }

                    <button type="button" class="btn btn-outline-primary" @onclick="AddDebt">
                        <i class="bi bi-plus-circle"></i> @Localizer["Debts_Step1_AddDebt"]
                    </button>
                </div>
            }

            <!-- Error Message -->
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-triangle"></i> @_errorMessage
                </div>
            }

            <!-- Success Message -->
            @if (!string.IsNullOrEmpty(_successMessage))
            {
                <div class="alert alert-success" role="alert">
                    <i class="bi bi-check-circle"></i> @_successMessage
                </div>
            }

            <!-- Action Buttons -->
            <div class="d-flex justify-content-between mt-4">
                <button type="button" class="btn btn-secondary" @onclick="@(EventCallback.Factory.Create(this, GoBack))">
                    <i class="bi bi-arrow-left"></i> @Localizer["Debts_Step1_PreviousStep"]
                </button>
                <button type="submit" class="btn btn-primary" disabled="@_isSubmitting">
                    @if (_isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    }
                    @Localizer["Debts_Step1_SaveContinue"] <i class="bi bi-arrow-right"></i>
                </button>
            </div>
        </EditForm>
    }
</div>

