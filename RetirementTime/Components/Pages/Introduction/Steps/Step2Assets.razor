@using RetirementTime.Models.Introduction
@using RetirementTime.Components.Shared

<div class="intro-step step-header-animate" style="font-family: 'Manrope', sans-serif;">

    <header class="mb-4">
        <h1 class="font-headline text-5xl font-bold text-ne-primary mt-3 mb-2">@Localizer["Intro_Step3_Title"]</h1>
        <p class="font-body text-ne-on-surface-variant max-w-2xl text-lg leading-relaxed">
            @Localizer["Intro_Step3_Subtitle"]
        </p>
    </header>

    <div class="step-body-animate">
        <div class="bg-ne-surface-low rounded-xl px-8 pb-8 pt-5 shadow-[0px_24px_48px_rgba(29,28,22,0.05)] space-y-6">

            <!-- Savings & Investment Accounts -->
            <div class="assets-section">
                <h3 class="assets-section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-3"/><path d="M16 12h5v4h-5a2 2 0 0 1 0-4z"/></svg>
                    @Localizer["Intro_Step3_Section_Financial"]
                </h3>

                <div class="field-group">
                    <label class="field-question">@Localizer["Intro_Step3_HasSavingsAccount"]</label>
                    <YesNoToggle @bind-Value="Model.HasSavingsAccount"
                                 YesLabel="@Localizer["Intro_Step3_Yes"]"
                                 NoLabel="@Localizer["Intro_Step3_No"]" />
                </div>

                <div class="field-group">
                    <label class="field-question">@Localizer["Intro_Step3_InvestmentAccounts"]</label>
                    <div class="checklist">
                        <label class="checklist-item"><input type="checkbox" @bind="Model.HasTFSA" /><span class="checkbox-custom"></span><span>@Localizer["Intro_Step3_HasTFSA"]</span></label>
                        <label class="checklist-item"><input type="checkbox" @bind="Model.HasRRSP" /><span class="checkbox-custom"></span><span>@Localizer["Intro_Step3_HasRRSP"]</span></label>
                        <label class="checklist-item"><input type="checkbox" @bind="Model.HasRRIF" /><span class="checkbox-custom"></span><span>@Localizer["Intro_Step3_HasRRIF"]</span></label>
                        <label class="checklist-item"><input type="checkbox" @bind="Model.HasFHSA" /><span class="checkbox-custom"></span><span>@Localizer["Intro_Step3_HasFHSA"]</span></label>
                        <label class="checklist-item"><input type="checkbox" @bind="Model.HasRESP" /><span class="checkbox-custom"></span><span>@Localizer["Intro_Step3_HasRESP"]</span></label>
                        <label class="checklist-item"><input type="checkbox" @bind="Model.HasRDSP" /><span class="checkbox-custom"></span><span>@Localizer["Intro_Step3_HasRDSP"]</span></label>
                        <label class="checklist-item"><input type="checkbox" @bind="Model.HasNonRegistered" /><span class="checkbox-custom"></span><span>@Localizer["Intro_Step3_HasNonRegistered"]</span></label>
                        <label class="checklist-item"><input type="checkbox" @bind="Model.HasPension" /><span class="checkbox-custom"></span><span>@Localizer["Intro_Step3_HasPension"]</span></label>
                    </div>
                </div>
            </div>

            <!-- Physical Assets -->
            <div class="assets-section">
                <h3 class="assets-section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    @Localizer["Intro_Step3_Section_Physical"]
                </h3>

                <div class="field-group">
                    <label class="field-question">@Localizer["Intro_Step3_PhysicalAssets"]</label>
                    <div class="checklist">
                        <label class="checklist-item"><input type="checkbox" @bind="Model.HasPrincipalResidence" /><span class="checkbox-custom"></span><span>@Localizer["Intro_Step3_HasPrincipalResidence"]</span></label>
                        <label class="checklist-item"><input type="checkbox" @bind="Model.HasCar" /><span class="checkbox-custom"></span><span>@Localizer["Intro_Step3_HasCar"]</span></label>
                        <label class="checklist-item"><input type="checkbox" @bind="Model.HasInvestmentProperty" /><span class="checkbox-custom"></span><span>@Localizer["Intro_Step3_HasInvestmentProperty"]</span></label>
                        <label class="checklist-item"><input type="checkbox" @bind="Model.HasBusiness" /><span class="checkbox-custom"></span><span>@Localizer["Intro_Step3_HasBusiness"]</span></label>
                        <label class="checklist-item"><input type="checkbox" @bind="Model.HasIncorporation" /><span class="checkbox-custom"></span><span>@Localizer["Intro_Step3_HasIncorporation"]</span></label>
                        <label class="checklist-item"><input type="checkbox" @bind="Model.HasPreciousMetals" /><span class="checkbox-custom"></span><span>@Localizer["Intro_Step3_HasPreciousMetals"]</span></label>
                        <label class="checklist-item"><input type="checkbox" @bind="Model.HasOtherHardAssets" /><span class="checkbox-custom"></span><span>@Localizer["Intro_Step3_HasOtherHardAssets"]</span></label>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
