<div class="intro-step step-header-animate" style="font-family: 'Manrope', sans-serif;">

    <header class="mb-4">
        <h1 class="font-headline text-5xl font-bold text-ne-primary mt-3 mb-2">@Localizer["Intro_Step1_Title"]</h1>
        <p class="font-body text-ne-on-surface-variant max-w-2xl text-lg leading-relaxed">
            @Localizer["Intro_Step1_Body"]
        </p>
    </header>

    <div class="step-body-animate">
        <p class="font-body text-ne-on-surface-variant max-w-2xl text-base leading-relaxed mb-6">
            @Localizer["Intro_Step1_Body2"]
        </p>
        <button class="inline-flex items-center gap-3 px-8 py-3 rounded font-label font-bold text-sm tracking-wide"
                style="background:var(--ne-primary);color:#fff;border:none;cursor:pointer;transition:background 0.2s ease;box-shadow:0 4px 14px var(--ne-primary-shadow);"
                @onclick="OnStart">
            @Localizer["Intro_LetsGetStarted"] →
        </button>
    </div>
</div>
