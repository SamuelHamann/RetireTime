@page "/login"
@layout HomeLayout
@rendermode InteractiveServer

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <h1>@Localizer["Login_WelcomeBack"]</h1>
            <p>@Localizer["Login_Subtitle"]</p>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-error">
                @_errorMessage
            </div>
        }

        <EditForm Model="@LoginModel" OnValidSubmit="@HandleLogin" class="login-form">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="email">@Localizer["Login_Email"]</label>
                <InputText id="email" type="email" @bind-Value="LoginModel.Email" class="form-input" placeholder="john.doe@example.com" />
                <ValidationMessage For="@(() => LoginModel.Email)" />
            </div>

            <div class="form-group">
                <label for="password">@Localizer["Login_Password"]</label>
                <InputText id="password" type="password" @bind-Value="LoginModel.Password" class="form-input" placeholder="••••••••" />
                <ValidationMessage For="@(() => LoginModel.Password)" />
            </div>

            <div class="form-options">
                <label class="checkbox-label">
                    <InputCheckbox @bind-Value="LoginModel.RememberMe" />
                    <span>@Localizer["Login_RememberMe"]</span>
                </label>
                <a href="/forgot-password" class="forgot-link">@Localizer["Login_ForgotPassword"]</a>
            </div>

            <button type="submit" class="submit-button">@Localizer["Login_LoginButton"]</button>
        </EditForm>

        <div class="divider">
            <span>@Localizer["Login_OrContinueWith"]</span>
        </div>

        <button class="google-button" @onclick="HandleGoogleLogin">
            <svg class="google-icon" viewBox="0 0 24 24">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            @Localizer["Login_GoogleSignIn"]
        </button>

        <div class="login-footer">
            <p>@Localizer["Login_NoAccount"] <a href="/signup" class="signup-link">@Localizer["Login_SignUpLink"]</a></p>
        </div>
    </div>
</div>

