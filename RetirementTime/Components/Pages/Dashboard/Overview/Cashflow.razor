@page "/scenario/{scenarioId:long}/cashflow"
@layout DashboardLayout
@rendermode InteractiveServer
@using RetirementTime.Resources.Dashboard
@inject IStringLocalizer<DashboardResources> DashboardLocalizer

<div class="intro-step">
    <div class="step-header-animate">
        <h1 class="font-headline text-5xl font-bold text-ne-primary mt-3 mb-2">@DashboardLocalizer["Sidebar_Cashflow"]</h1>
        <p class="font-body text-ne-on-surface-variant text-base leading-relaxed">
            A projection of your annual income and expenses over time.
        </p>
    </div>
    <div class="step-body-animate">
        <div class="cashflow-toggle-row">
            <button class="cashflow-toggle-btn @(_isMonthly ? "" : "active")" @onclick="() => SetPeriod(false)">
                @DashboardLocalizer["Cashflow_Toggle_Yearly"]
            </button>
            <button class="cashflow-toggle-btn @(_isMonthly ? "active" : "")" @onclick="() => SetPeriod(true)">
                @DashboardLocalizer["Cashflow_Toggle_Monthly"]
            </button>
        </div>

        <h2 class="cashflow-graph-title">@DashboardLocalizer["Cashflow_Title_Current"]</h2>
        <div id="cashflow-chart" style="width:100%;"></div>

        <h2 class="cashflow-graph-title" style="margin-top: 3rem;">@DashboardLocalizer["Cashflow_Title_OverTime"]</h2>
        <div id="cashflow-bar-chart" style="width:100%; height:500px;"></div>
    </div>
</div>
