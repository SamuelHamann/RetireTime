@page "/scenario/{scenarioId:long}/income/timeline/{timelineId:long}/defined-benefits"
@layout DashboardLayout
@rendermode InteractiveServer

@using RetirementTime.Models.Income

<div class="intro-step">
    <div class="step-header-animate">
        <h1 class="font-headline text-5xl font-bold text-ne-primary mt-3 mb-2">@Localizer["Income_DefinedBenefits_Title"]</h1>
        <p class="font-body text-ne-on-surface-variant text-base leading-relaxed">@Localizer["Income_DefinedBenefits_Subtitle"]</p>
    </div>
    <div class="step-body-animate">
        <div class="bg-ne-surface-low rounded-xl px-8 pb-8 pt-5 shadow-sm">

            <div class="income-section-header">
                <h2 class="assets-section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                        <path d="M2 17l10 5 10-5"/>
                        <path d="M2 12l10 5 10-5"/>
                    </svg>
                    @Localizer["Income_DefinedBenefits_SectionTitle"]
                </h2>
            </div>

            <p class="field-sublabel" style="margin-bottom: 1.25rem;">@Localizer["Income_DefinedBenefits_Hint"]</p>

            @if (_isLoading)
            {
                <div class="intro-loading">
                    <p>Loading...</p>
                </div>
            }
            else
            {
                <div class="income-items-list">
                    @foreach (var item in _pensionItems)
                    {
                        var index = _pensionItems.IndexOf(item);

                        <div class="income-item-card">

                            <div class="income-item-header">
                                <span class="income-item-number">@string.Format(Localizer["Income_DefinedBenefits_Item"].Value, index + 1)</span>
                                <button type="button" class="income-remove-btn" @onclick="async () => await RemovePension(item)">
                                    @Localizer["Income_Remove"]
                                </button>
                            </div>

                            <div class="income-fields-grid">

                                <!-- Plan Name -->
                                <div class="field-group income-field-full">
                                    <label class="field-question">@Localizer["Income_DefinedBenefits_Name"]</label>
                                    <input type="text" class="field-input" @bind="item.Name" @bind:after="async () => await SavePension(item)" />
                                </div>

                                <!-- Start Age -->
                                <div class="field-group">
                                    <label class="field-question">@Localizer["Income_DefinedBenefits_StartAge"]</label>
                                    <input type="number" class="field-input" @bind="item.StartAge" @bind:after="async () => await SavePension(item)" min="50" max="100" step="1" />
                                </div>

                                <!-- Benefits Pre/Post 65 -->
                                <div class="field-group">
                                    <label class="field-question">@Localizer["Income_DefinedBenefits_BenefitsPre65"]</label>
                                    <div class="money-input-wrapper">
                                        <input type="number" class="field-input money-input" @bind="item.BenefitsPre65" @bind:after="async () => await SavePension(item)" min="0" step="0.01" />
                                    </div>
                                </div>
                                <div class="field-group">
                                    <label class="field-question">@Localizer["Income_DefinedBenefits_BenefitsPost65"]</label>
                                    <div class="money-input-wrapper">
                                        <input type="number" class="field-input money-input" @bind="item.BenefitsPost65" @bind:after="async () => await SavePension(item)" min="0" step="0.01" />
                                    </div>
                                </div>

                                <!-- Percentages -->
                                <div class="field-group">
                                    <label class="field-question">@Localizer["Income_DefinedBenefits_PercentIndexedToInflation"]</label>
                                    <div class="percent-input-wrapper">
                                        <input type="number" class="field-input percent-input" @bind="item.PercentIndexedToInflation" @bind:after="async () => await SavePension(item)" min="0" max="100" step="1" />
                                    </div>
                                </div>
                                <div class="field-group">
                                    <label class="field-question">@Localizer["Income_DefinedBenefits_PercentSurvivorBenefits"]</label>
                                    <div class="percent-input-wrapper">
                                        <input type="number" class="field-input percent-input" @bind="item.PercentSurvivorBenefits" @bind:after="async () => await SavePension(item)" min="0" max="100" step="1" />
                                    </div>
                                </div>

                                <!-- RRSP Adjustment -->
                                <div class="field-group">
                                    <label class="field-question">@Localizer["Income_DefinedBenefits_RrspAdjustment"]</label>
                                    <div class="money-input-wrapper">
                                        <input type="number" class="field-input money-input" @bind="item.RrspAdjustment" @bind:after="async () => await SavePension(item)" min="0" step="0.01" />
                                    </div>
                                </div>

                            </div>
                        </div>
                    }
                </div>
            }

            <button type="button" class="income-add-main-btn" @onclick="async () => await AddPension()">
                + @Localizer["Income_DefinedBenefits_AddPension"]
            </button>

        </div>
    </div>
    <div class="income-next-row">
        <button class="income-next-btn" @onclick="NavigateNext">
            <span>@Localizer["Income_Next"]</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
        </button>
    </div>
</div>
