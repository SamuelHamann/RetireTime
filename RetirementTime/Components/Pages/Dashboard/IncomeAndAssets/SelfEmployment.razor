@page "/scenario/{scenarioId:long}/income/timeline/{timelineId:long}/self-employment"
@layout DashboardLayout
@rendermode InteractiveServer

@using RetirementTime.Models.Income

<div class="intro-step">
    <div class="step-header-animate">
        <h1 class="font-headline text-5xl font-bold text-ne-primary mt-3 mb-2">@Localizer["Income_SelfEmployment_Title"]</h1>
        <p class="font-body text-ne-on-surface-variant text-base leading-relaxed">@Localizer["Income_SelfEmployment_Subtitle"]</p>
    </div>
    <div class="step-body-animate">
        <div class="bg-ne-surface-low rounded-xl px-8 pb-8 pt-5 shadow-sm">

            <div class="income-section-header">
                <h2 class="assets-section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                        <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                    @Localizer["Income_SelfEmployment_SectionTitle"]
                </h2>
            </div>

            <p class="field-sublabel" style="margin-bottom: 1.25rem;">@Localizer["Income_SelfEmployment_Hint"]</p>

            @if (_isLoading)
            {
                <div class="intro-loading">
                    <p>Loading...</p>
                </div>
            }
            else
            {
                <div class="income-items-list">
                    @foreach (var item in _selfEmploymentItems)
                    {
                        var index = _selfEmploymentItems.IndexOf(item);

                        <div class="income-item-card">

                            <div class="income-item-header">
                                <span class="income-item-number">@string.Format(Localizer["Income_SelfEmployment_Item"].Value, index + 1)</span>
                                <button type="button" class="income-remove-btn" @onclick="async () => await RemoveSelfEmployment(item)">
                                    @Localizer["Income_Remove"]
                                </button>
                            </div>

                            <div class="income-fields-grid">

                                <!-- Business Name -->
                                <div class="field-group income-field-full">
                                    <label class="field-question">@Localizer["Income_SelfEmployment_Name"]</label>
                                    <input type="text" class="field-input" @bind="item.Name" @bind:after="async () => await SaveSelfEmployment(item)" />
                                </div>

                                <!-- Salary -->
                                <div class="field-group">
                                    <label class="field-question">@Localizer["Income_SelfEmployment_GrossSalary"]</label>
                                    <div class="money-input-wrapper">
                                        <input type="number" class="field-input money-input" @bind="item.GrossSalary" @bind:after="async () => await SaveSelfEmployment(item)" min="0" step="0.01" />
                                    </div>
                                    <select class="field-select" @bind="item.GrossSalaryFrequencyId" @bind:after="async () => await SaveSelfEmployment(item)">
                                        @foreach (var f in _frequencies) { <option value="@f.Id">@f.Name</option> }
                                    </select>
                                </div>
                                <div class="field-group">
                                    <label class="field-question">@Localizer["Income_SelfEmployment_NetSalary"]</label>
                                    <div class="money-input-wrapper">
                                        <input type="number" class="field-input money-input" @bind="item.NetSalary" @bind:after="async () => await SaveSelfEmployment(item)" min="0" step="0.01" />
                                    </div>
                                    <select class="field-select" @bind="item.NetSalaryFrequencyId" @bind:after="async () => await SaveSelfEmployment(item)">
                                        @foreach (var f in _frequencies) { <option value="@f.Id">@f.Name</option> }
                                    </select>
                                </div>

                                <!-- Dividends -->
                                <div class="field-group">
                                    <label class="field-question">@Localizer["Income_SelfEmployment_GrossDividends"]</label>
                                    <div class="money-input-wrapper">
                                        <input type="number" class="field-input money-input" @bind="item.GrossDividends" @bind:after="async () => await SaveSelfEmployment(item)" min="0" step="0.01" />
                                    </div>
                                    <select class="field-select" @bind="item.GrossDividendsFrequencyId" @bind:after="async () => await SaveSelfEmployment(item)">
                                        @foreach (var f in _frequencies) { <option value="@f.Id">@f.Name</option> }
                                    </select>
                                </div>
                                <div class="field-group">
                                    <label class="field-question">@Localizer["Income_SelfEmployment_NetDividends"]</label>
                                    <div class="money-input-wrapper">
                                        <input type="number" class="field-input money-input" @bind="item.NetDividends" @bind:after="async () => await SaveSelfEmployment(item)" min="0" step="0.01" />
                                    </div>
                                    <select class="field-select" @bind="item.NetDividendsFrequencyId" @bind:after="async () => await SaveSelfEmployment(item)">
                                        @foreach (var f in _frequencies) { <option value="@f.Id">@f.Name</option> }
                                    </select>
                                </div>

                            </div>
                        </div>
                    }
                </div>
            }

            <button type="button" class="income-add-main-btn" @onclick="async () => await AddSelfEmployment()">
                + @Localizer["Income_SelfEmployment_AddSelfEmployment"]
            </button>

        </div>
    </div>
    <div class="income-next-row">
        <button class="income-next-btn" @onclick="NavigateNext">
            <span>@Localizer["Income_Next"]</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
        </button>
    </div>
</div>
