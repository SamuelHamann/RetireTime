@page "/scenario/{scenarioId:long}/assets/physical-assets"
@layout DashboardLayout
@rendermode InteractiveServer

@using RetirementTime.Models.Asset

<div class="intro-step">
    <div class="step-header-animate">
        <h1 class="font-headline text-5xl font-bold text-ne-primary mt-3 mb-2">@Localizer["Assets_PhysicalAssets_Title"]</h1>
        <p class="font-body text-ne-on-surface-variant text-base leading-relaxed">@Localizer["Assets_PhysicalAssets_Subtitle"]</p>
    </div>
    <div class="step-body-animate">
        <div class="bg-ne-surface-low rounded-xl px-8 pb-8 pt-5 shadow-sm">

            <div class="income-section-header">
                <h2 class="assets-section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                    </svg>
                    @Localizer["Assets_PhysicalAssets_SectionTitle"]
                </h2>
            </div>

            <p class="field-sublabel" style="margin-bottom: 1.25rem;">@Localizer["Assets_PhysicalAssets_Hint"]</p>

            @if (_isLoading)
            {
                <div class="intro-loading"><p>Loading...</p></div>
            }
            else
            {
                <div class="income-items-list">
                    @foreach (var asset in _assetItems)
                    {
                        var index = _assetItems.IndexOf(asset);
                        <div class="income-item-card">
                            <div class="income-item-header">
                                <span class="income-item-number">@string.Format(Localizer["Assets_PhysicalAssets_Item"].Value, index + 1)</span>
                                <button type="button" class="income-remove-btn" @onclick="async () => await RemoveAsset(asset)">@Localizer["Assets_Remove"]</button>
                            </div>
                            <div class="income-fields-grid">
                                <div class="field-group income-field-full">
                                    <label class="field-question">@Localizer["Assets_PhysicalAssets_Name"]</label>
                                    <input type="text" class="field-input" @bind="asset.Name" @bind:after="async () => await SaveAsset(asset)" />
                                </div>
                                <div class="field-group">
                                    <label class="field-question">@Localizer["Assets_PhysicalAssets_AssetType"]</label>
                                    <select class="field-select" @bind="asset.AssetTypeId" @bind:after="async () => await SaveAsset(asset)">
                                        @foreach (var type in _assetTypes)
                                        {
                                            <option value="@type.Id">@type.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="field-group">
                                    <label class="field-question">@Localizer["Assets_PhysicalAssets_EstimatedValue"]</label>
                                    <div class="money-input-wrapper">
                                        <input type="number" class="field-input money-input" @bind="asset.EstimatedValue" @bind:after="async () => await SaveAsset(asset)" min="0" step="0.01" />
                                    </div>
                                </div>
                                <div class="field-group">
                                    <label class="field-question">@Localizer["Assets_PhysicalAssets_AdjustedCostBasis"]</label>
                                    <div class="money-input-wrapper">
                                        <input type="number" class="field-input money-input" @bind="asset.AdjustedCostBasis" @bind:after="async () => await SaveAsset(asset)" min="0" step="0.01" />
                                    </div>
                                </div>

                                <div class="income-subsection">
                                    <span class="income-subsection-label">@Localizer["Assets_PhysicalAssets_IsPersonalProperty"]</span>
                                    <YesNoToggle Value="asset.IsConsideredPersonalProperty"
                                                 YesLabel="@Localizer["Yes"]"
                                                 NoLabel="@Localizer["No"]"
                                                 ValueChanged="async v => { asset.IsConsideredPersonalProperty = v; await SaveAsset(asset); }" />
                                </div>

                                <div class="income-subsection">
                                    <span class="income-subsection-label">@Localizer["Assets_PhysicalAssets_IsRetirementAsset"]</span>
                                    <YesNoToggle Value="asset.IsConsideredAsARetirementAsset"
                                                 YesLabel="@Localizer["Yes"]"
                                                 NoLabel="@Localizer["No"]"
                                                 ValueChanged="async v => { asset.IsConsideredAsARetirementAsset = v; await SaveAsset(asset); }" />
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <button type="button" class="income-add-main-btn" @onclick="async () => await AddAsset()">
                    + @Localizer["Assets_PhysicalAssets_AddAsset"]
                </button>
            }
        </div>
    </div>
</div>
