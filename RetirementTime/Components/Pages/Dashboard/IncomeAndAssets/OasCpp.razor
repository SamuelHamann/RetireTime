@page "/scenario/{scenarioId:long}/income/timeline/{timelineId:long}/oas-cpp"
@layout DashboardLayout
@rendermode InteractiveServer

@using RetirementTime.Models.Income

<div class="intro-step">
    <div class="step-header-animate">
        <h1 class="font-headline text-5xl font-bold text-ne-primary mt-3 mb-2">@Localizer["Income_OasCpp_Title"]</h1>
        <p class="font-body text-ne-on-surface-variant text-base leading-relaxed">@Localizer["Income_OasCpp_Subtitle"]</p>
    </div>
    <div class="step-body-animate">
        <div class="bg-ne-surface-low rounded-xl px-8 pb-8 pt-5 shadow-sm">

            <div class="income-section-header">
                <h2 class="assets-section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                    @Localizer["Income_OasCpp_SectionTitle"]
                </h2>
            </div>

            <p class="field-sublabel" style="margin-bottom: 1.5rem;">@Localizer["Income_OasCpp_Hint"]</p>

            @if (_isLoading)
            {
                <div class="intro-loading"><p>Loading...</p></div>
            }
            else
            {
                <div class="income-fields-grid">
                    <div class="field-group">
                        <label class="field-question">@Localizer["Income_OasCpp_IncomeLastYear"]</label>
                        <div class="money-input-wrapper">
                            <input type="number" class="field-input money-input" @bind="_model.IncomeLastYear" @bind:after="SaveAsync" min="0" step="0.01" />
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="field-question">@Localizer["Income_OasCpp_Income2YearsAgo"]</label>
                        <div class="money-input-wrapper">
                            <input type="number" class="field-input money-input" @bind="_model.Income2YearsAgo" @bind:after="SaveAsync" min="0" step="0.01" />
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="field-question">@Localizer["Income_OasCpp_Income3YearsAgo"]</label>
                        <div class="money-input-wrapper">
                            <input type="number" class="field-input money-input" @bind="_model.Income3YearsAgo" @bind:after="SaveAsync" min="0" step="0.01" />
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="field-question">@Localizer["Income_OasCpp_Income4YearsAgo"]</label>
                        <div class="money-input-wrapper">
                            <input type="number" class="field-input money-input" @bind="_model.Income4YearsAgo" @bind:after="SaveAsync" min="0" step="0.01" />
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="field-question">@Localizer["Income_OasCpp_Income5YearsAgo"]</label>
                        <div class="money-input-wrapper">
                            <input type="number" class="field-input money-input" @bind="_model.Income5YearsAgo" @bind:after="SaveAsync" min="0" step="0.01" />
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="field-question">@Localizer["Income_OasCpp_YearsSpentInCanada"]</label>
                        <input type="number" class="field-input" @bind="_model.YearsSpentInCanada" @bind:after="SaveAsync" min="0" max="65" step="1" />
                    </div>
                </div>
            }

        </div>
    </div>
    <div class="income-next-row">
        <button class="income-next-btn" @onclick="NavigateNext">
            <span>@Localizer["Income_Next"]</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
        </button>
    </div>
</div>

