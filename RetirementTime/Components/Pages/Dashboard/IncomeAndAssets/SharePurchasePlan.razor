@page "/scenario/{scenarioId:long}/income/timeline/{timelineId:long}/share-purchase-plan"
@layout DashboardLayout
@rendermode InteractiveServer

@using RetirementTime.Models.Income
@using RetirementTime.Components.Shared

<div class="intro-step">
    <div class="step-header-animate">
        <h1 class="font-headline text-5xl font-bold text-ne-primary mt-3 mb-2">@Localizer["Income_SharePurchasePlan_Title"]</h1>
        <p class="font-body text-ne-on-surface-variant text-base leading-relaxed">@Localizer["Income_SharePurchasePlan_Subtitle"]</p>
    </div>
    <div class="step-body-animate">
        <div class="bg-ne-surface-low rounded-xl px-8 pb-8 pt-5 shadow-sm">

            <div class="income-section-header">
                <h2 class="assets-section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>
                    </svg>
                    @Localizer["Income_SharePurchasePlan_SectionTitle"]
                </h2>
            </div>

            <p class="field-sublabel" style="margin-bottom: 1.25rem;">@Localizer["Income_SharePurchasePlan_Hint"]</p>

            @if (_isLoading)
            {
                <div class="intro-loading"><p>Loading...</p></div>
            }
            else
            {
                <div class="income-items-list">
                    @foreach (var item in _planItems)
                    {
                        var index = _planItems.IndexOf(item);
                        <div class="income-item-card">
                            <div class="income-item-header">
                                <span class="income-item-number">@string.Format(Localizer["Income_SharePurchasePlan_Item"].Value, index + 1)</span>
                                <button type="button" class="income-remove-btn" @onclick="async () => await RemovePlan(item)">@Localizer["Income_Remove"]</button>
                            </div>
                            <div class="income-fields-grid">
                                <div class="field-group income-field-full">
                                    <label class="field-question">@Localizer["Income_SharePurchasePlan_Name"]</label>
                                    <input type="text" class="field-input" @bind="item.Name" @bind:after="async () => await SavePlan(item)" />
                                </div>
                                <div class="field-group income-field-full">
                                    <label class="field-question">@Localizer["Income_SharePurchasePlan_UseFlatAmount"]</label>
                                    <YesNoToggle @bind-Value="item.UseFlatAmountInsteadOfPercent" YesLabel="@Localizer["Yes"]" NoLabel="@Localizer["No"]" @bind-Value:after="async () => await SavePlan(item)" />
                                </div>
                                <div class="field-group">
                                    <label class="field-question">@Localizer["Income_SharePurchasePlan_PercentEmployee"]</label>
                                    <div class="percent-input-wrapper">
                                        <input type="number" class="field-input percent-input" @bind="item.PercentOfSalaryEmployee" @bind:after="async () => await SavePlan(item)" min="0" step="0.01" />
                                    </div>
                                </div>
                                <div class="field-group">
                                    <label class="field-question">@Localizer["Income_SharePurchasePlan_PercentEmployer"]</label>
                                    <div class="percent-input-wrapper">
                                        <input type="number" class="field-input percent-input" @bind="item.PercentOfSalaryEmployer" @bind:after="async () => await SavePlan(item)" min="0" step="0.01" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            <button type="button" class="income-add-main-btn" @onclick="async () => await AddPlan()">
                + @Localizer["Income_SharePurchasePlan_AddPlan"]
            </button>

        </div>
    </div>
    <div class="income-next-row">
        <button class="income-next-btn" @onclick="NavigateNext">
            <span>@Localizer["Income_Next"]</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
        </button>
    </div>
</div>

