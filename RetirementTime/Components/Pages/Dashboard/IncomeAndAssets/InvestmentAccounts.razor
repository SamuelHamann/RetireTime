@page "/scenario/{scenarioId:long}/assets/investment-accounts"
@layout DashboardLayout
@rendermode InteractiveServer

@using RetirementTime.Domain.Entities.Common
@using RetirementTime.Models.Asset

<div class="intro-step">
    <div class="step-header-animate">
        <h1 class="font-headline text-5xl font-bold text-ne-primary mt-3 mb-2">@Localizer["Assets_InvestmentAccounts_Title"]</h1>
        <p class="font-body text-ne-on-surface-variant text-base leading-relaxed">@Localizer["Assets_InvestmentAccounts_Subtitle"]</p>
    </div>
    <div class="step-body-animate">
        <div class="bg-ne-surface-low rounded-xl px-8 pb-8 pt-5 shadow-sm">

            <div class="income-section-header">
                <h2 class="assets-section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                    </svg>
                    @Localizer["Assets_InvestmentAccounts_SectionTitle"]
                </h2>
            </div>

            <p class="field-sublabel" style="margin-bottom: 1.25rem;">@Localizer["Assets_InvestmentAccounts_Hint"]</p>

            @if (_isLoading)
            {
                <div class="intro-loading"><p>Loading...</p></div>
            }
            else
            {
                <div class="income-items-list">
                    @foreach (var account in _accountItems)
                    {
                        var index = _accountItems.IndexOf(account);
                        <div class="income-item-card">
                            <div class="income-item-header">
                                <span class="income-item-number">@string.Format(Localizer["Assets_InvestmentAccounts_Item"].Value, index + 1)</span>
                                <button type="button" class="income-remove-btn" @onclick="async () => await RemoveAccount(account)">@Localizer["Assets_Remove"]</button>
                            </div>

                            <div class="income-fields-grid">
                                <div class="field-group income-field-full">
                                    <label class="field-question">@Localizer["Assets_InvestmentAccounts_AccountName"]</label>
                                    <input type="text" class="field-input" @bind="account.AccountName" @bind:after="async () => await SaveAccount(account)" />
                                </div>
                                <div class="field-group">
                                    <label class="field-question">@Localizer["Assets_InvestmentAccounts_AccountType"]</label>
                                    <select class="field-select" @bind="account.AccountTypeId" @bind:after="async () => await SaveAccount(account)">
                                        @foreach (var type in _accountTypes)
                                        {
                                            <option value="@type.Id">@type.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="field-group">
                                    <label class="field-question">@Localizer["Assets_InvestmentAccounts_AdjustedCostBasis"]</label>
                                    <div class="money-input-wrapper">
                                        <input type="number" class="field-input money-input" @bind="account.AdjustedCostBasis" @bind:after="async () => await SaveAccount(account)" min="0" step="0.01" />
                                    </div>
                                </div>

                                <div class="income-subsection">
                                    <span class="income-subsection-label">@Localizer["Assets_InvestmentAccounts_UseIndividualHoldings"]</span>
                                    <YesNoToggle Value="account.UseIndividualHoldings"
                                                 YesLabel="@Localizer["Yes"]"
                                                 NoLabel="@Localizer["No"]"
                                                 ValueChanged="async v => { account.UseIndividualHoldings = v; await SaveAccount(account); }" />
                                </div>

                                @if (!account.UseIndividualHoldings)
                                {
                                    <div class="field-group income-field-full">
                                        <label class="field-question">@Localizer["Assets_InvestmentAccounts_TotalValue"]</label>
                                        <div class="money-input-wrapper">
                                            <input type="number" class="field-input money-input" @bind="account.CurrentTotalValue" @bind:after="async () => await SaveAccount(account)" min="0" step="0.01" />
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="income-subsection">
                                        <span class="income-subsection-label">@Localizer["Assets_InvestmentAccounts_Holdings_SectionLabel"]</span>
                                        <div class="income-other-list">
                                            @foreach (var holding in account.Holdings)
                                            {
                                                <div class="investment-holding-card">
                                                    <div class="income-fields-grid">
                                                        <div class="field-group income-field-full">
                                                            <label class="field-question">@Localizer["Assets_InvestmentAccounts_Holdings_AssetName"]</label>
                                                            <input type="text" class="field-input" @bind="holding.AssetName" @bind:after="async () => await SaveHolding(holding)" />
                                                        </div>
                                                        <div class="field-group">
                                                            <label class="field-question">@Localizer["Assets_InvestmentAccounts_Holdings_CurrentValue"]</label>
                                                            <div class="money-input-wrapper">
                                                                <input type="number" class="field-input money-input" @bind="holding.CurrentValue" @bind:after="async () => await SaveHolding(holding)" min="0" step="0.01" />
                                                            </div>
                                                        </div>
                                                        <div class="field-group">
                                                            <label class="field-question">@Localizer["Assets_InvestmentAccounts_Holdings_AdjustedCostBasis"]</label>
                                                            <div class="money-input-wrapper">
                                                                <input type="number" class="field-input money-input" @bind="holding.AdjustedCostBasis" @bind:after="async () => await SaveHolding(holding)" min="0" step="0.01" />
                                                            </div>
                                                        </div>

                                                        <div class="income-subsection">
                                                            <span class="income-subsection-label">@Localizer["Assets_InvestmentAccounts_Holdings_IsPubliclyTraded"]</span>
                                                            <YesNoToggle Value="holding.IsPubliclyTraded"
                                                                         YesLabel="@Localizer["Yes"]"
                                                                         NoLabel="@Localizer["No"]"
                                                                         ValueChanged="async v => { holding.IsPubliclyTraded = v; await SaveHolding(holding); }" />
                                                        </div>

                                                        @if (holding.IsPubliclyTraded)
                                                        {
                                                            <div class="field-group">
                                                                <label class="field-question">@Localizer["Assets_InvestmentAccounts_Holdings_TickerSymbol"]</label>
                                                                <input type="text" class="field-input" @bind="holding.TickerSymbol" @bind:after="async () => await SaveHolding(holding)" style="max-width: 160px;" />
                                                            </div>
                                                        }
                                                    </div>
                                                    <div class="holding-remove-row">
                                                        <button type="button" class="income-remove-btn" @onclick="async () => await RemoveHolding(account, holding)">@Localizer["Assets_Remove"]</button>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                        <button type="button" class="income-add-sub-btn" @onclick="async () => await AddHolding(account)">
                                            + @Localizer["Assets_InvestmentAccounts_Holdings_AddHolding"]
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>

                <button type="button" class="income-add-main-btn" @onclick="async () => await AddAccount()">
                    + @Localizer["Assets_InvestmentAccounts_AddAccount"]
                </button>
            }
        </div>
    </div>
    <div class="income-next-row">
        <button class="income-next-btn" @onclick="NavigateNext">
            <span>@Localizer["Assets_Next"]</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
        </button>
    </div>
</div>
