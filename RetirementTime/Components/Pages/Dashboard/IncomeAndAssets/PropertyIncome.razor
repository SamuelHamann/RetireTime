@page "/scenario/{scenarioId:long}/income/timeline/{timelineId:long}/real-estate-income"
@layout DashboardLayout
@rendermode InteractiveServer

@using RetirementTime.Models.Income

<div class="intro-step">
    <div class="step-header-animate">
        <h1 class="font-headline text-5xl font-bold text-ne-primary mt-3 mb-2">@Localizer["Income_PropertyIncome_Title"]</h1>
        <p class="font-body text-ne-on-surface-variant text-base leading-relaxed">@Localizer["Income_PropertyIncome_Subtitle"]</p>
    </div>
    <div class="step-body-animate">
        <div class="bg-ne-surface-low rounded-xl px-8 pb-8 pt-5 shadow-sm">

            <div class="income-section-header">
                <h2 class="assets-section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                    @Localizer["Income_PropertyIncome_SectionTitle"]
                </h2>
            </div>

            <p class="field-sublabel" style="margin-bottom: 1.25rem;">@Localizer["Income_PropertyIncome_Hint"]</p>

            @if (_isLoading)
            {
                <div class="intro-loading"><p>Loading...</p></div>
            }
            else
            {
                <div class="income-items-list">
                    @foreach (var item in _incomeItems)
                    {
                        var index = _incomeItems.IndexOf(item);
                        <div class="income-item-card">
                            <div class="income-item-header">
                                <span class="income-item-number">@string.Format(Localizer["Income_PropertyIncome_Item"].Value, index + 1)</span>
                                <button type="button" class="income-remove-btn" @onclick="async () => await RemoveIncome(item)">@Localizer["Income_Remove"]</button>
                            </div>
                            <div class="income-fields-grid">
                                <div class="field-group income-field-full">
                                    <label class="field-question">@Localizer["Income_PropertyIncome_Name"]</label>
                                    @if (item.InvestmentPropertyId.HasValue)
                                    {
                                        <input type="text" class="field-input" value="@item.Name" disabled />
                                    }
                                    else
                                    {
                                        <input type="text" class="field-input" @bind="item.Name" @bind:after="async () => await SaveIncome(item)" />
                                    }
                                </div>
                                <div class="field-group">
                                    <label class="field-question">@Localizer["Income_PropertyIncome_Amount"]</label>
                                    <div class="money-input-wrapper">
                                        <input type="number" class="field-input money-input" @bind="item.Amount" @bind:after="async () => await SaveIncome(item)" min="0" step="0.01" />
                                    </div>
                                </div>
                                <div class="field-group">
                                    <label class="field-question">@Localizer["Income_PropertyIncome_Frequency"]</label>
                                    <select class="field-select" @bind="item.FrequencyId" @bind:after="async () => await SaveIncome(item)">
                                        @foreach (var freq in _frequencies)
                                        {
                                            <option value="@freq.Id">@freq.Name</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            <button type="button" class="income-add-main-btn" @onclick="async () => await AddIncome()">
                + @Localizer["Income_PropertyIncome_AddIncome"]
            </button>

        </div>
    </div>
</div>

