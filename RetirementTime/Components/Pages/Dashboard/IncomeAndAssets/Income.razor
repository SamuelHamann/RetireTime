@page "/scenario/{scenarioId:long}/income"
@layout DashboardLayout
@rendermode InteractiveServer

@using RetirementTime.Models.Income

<div class="intro-step">
    
        <div class="step-header-animate">
            <h1 class="font-headline text-5xl font-bold text-ne-primary mt-3 mb-2">@Localizer["Income_Title"]</h1>
            <p class="font-body text-ne-on-surface-variant text-base leading-relaxed">@Localizer["Income_Subtitle"]</p>
        </div>

        <div class="step-body-animate">

            <!-- Employment Income Section -->
            <div class="bg-ne-surface-low rounded-xl px-8 pb-8 pt-5 shadow-sm">

                <div class="income-section-header">
                    <h2 class="assets-section-title">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="2" y="7" width="20" height="14" rx="2"/>
                            <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
                            <line x1="12" y1="12" x2="12" y2="16"/>
                            <line x1="10" y1="14" x2="14" y2="14"/>
                        </svg>
                        @Localizer["Income_Employment_SectionTitle"]
                    </h2>
                </div>

                <p class="field-sublabel" style="margin-bottom: 1.25rem;">@Localizer["Income_Employment_Hint"]</p>
                 @if (_isLoading)
                 {
                     <div class="intro-loading">
                         <p>Loading...</p>
                     </div>
                 }
                 else
                 {
                    <div class="income-items-list">
                        @foreach (var item in _employmentItems)
                        {
                            var index = _employmentItems.IndexOf(item);

                            <div class="income-item-card">

                                <div class="income-item-header">
                                        <span class="income-item-number">@string.Format(Localizer["Income_Employment_Item"].Value, index + 1)</span>
                                        <button type="button" class="income-remove-btn" @onclick="async () => await RemoveEmployment(item)">
                                            @Localizer["Income_Remove"]
                                        </button>
                                    </div>

                                <div class="income-fields-grid">

                                    <!-- Employer Name -->
                                    <div class="field-group income-field-full">
                                        <label class="field-question">@Localizer["Income_Employment_EmployerName"]</label>
                                        <input type="text" class="field-input" @bind="item.EmployerName" @bind:after="async () => await SaveEmployment(item)" />
                                    </div>

                                    <!-- Salary -->
                                    <div class="field-group">
                                        <label class="field-question">@Localizer["Income_Employment_GrossSalary"]</label>
                                        <div class="money-input-wrapper">
                                            <input type="number" class="field-input money-input" @bind="item.GrossSalary" @bind:after="async () => await SaveEmployment(item)" min="0" step="0.01" />
                                        </div>
                                    </div>
                                    <div class="field-group">
                                        <label class="field-question">@Localizer["Income_Employment_NetSalary"]</label>
                                        <div class="money-input-wrapper">
                                            <input type="number" class="field-input money-input" @bind="item.NetSalary" @bind:after="async () => await SaveEmployment(item)" min="0" step="0.01" />
                                        </div>
                                    </div>

                                    <!-- Commissions & Tips -->
                                    <div class="field-group">
                                        <label class="field-question">@Localizer["Income_Employment_GrossCommissions"]</label>
                                        <div class="money-input-wrapper">
                                            <input type="number" class="field-input money-input" @bind="item.GrossCommissions" @bind:after="async () => await SaveEmployment(item)" min="0" step="0.01" />
                                        </div>
                                    </div>
                                    <div class="field-group">
                                        <label class="field-question">@Localizer["Income_Employment_NetCommissions"]</label>
                                        <div class="money-input-wrapper">
                                            <input type="number" class="field-input money-input" @bind="item.NetCommissions" @bind:after="async () => await SaveEmployment(item)" min="0" step="0.01" />
                                        </div>
                                    </div>

                                    <!-- Bonus -->
                                    <div class="field-group">
                                        <label class="field-question">@Localizer["Income_Employment_GrossBonus"]</label>
                                        <div class="money-input-wrapper">
                                            <input type="number" class="field-input money-input" @bind="item.GrossBonus" @bind:after="async () => await SaveEmployment(item)" min="0" step="0.01" />
                                        </div>
                                    </div>
                                    <div class="field-group">
                                        <label class="field-question">@Localizer["Income_Employment_NetBonus"]</label>
                                        <div class="money-input-wrapper">
                                            <input type="number" class="field-input money-input" @bind="item.NetBonus" @bind:after="async () => await SaveEmployment(item)" min="0" step="0.01" />
                                        </div>
                                    </div>

                                    <!-- Other Income -->
                                    <div class="income-subsection">
                                        <span class="income-subsection-label">@Localizer["Income_Employment_OtherIncome"]</span>

                                        @if (item.OtherIncomes.Count > 0)
                                        {
                                            <div class="income-other-list">
                                                @foreach (var other in item.OtherIncomes)
                                                {
                                                    <div class="income-other-item">
                                                            <div class="field-group">
                                                                <label class="field-question">@Localizer["Income_Employment_OtherIncomeName"]</label>
                                                                <input type="text" class="field-input" @bind="other.Name" @bind:after="async () => await SaveOtherIncome(other)"/>
                                                            </div>
                                                            <div class="field-group">
                                                                <label class="field-question">@Localizer["Income_Employment_OtherIncomeGross"]</label>
                                                                <div class="money-input-wrapper">
                                                                    <input type="number" class="field-input money-input" @bind="other.Gross" @bind:after="async () => await SaveOtherIncome(other)" min="0" step="0.01" />
                                                                </div>
                                                            </div>
                                                            <div class="field-group">
                                                                <label class="field-question">@Localizer["Income_Employment_OtherIncomeNet"]</label>
                                                                <div class="money-input-wrapper">
                                                                    <input type="number" class="field-input money-input" @bind="other.Net" @bind:after="async () => await SaveOtherIncome(other)" min="0" step="0.01" />
                                                                </div>
                                                            </div>
                                                            <div class="income-remove-cell">
                                                                <button type="button" class="income-remove-btn" @onclick="async () => await RemoveOtherIncome(item, other)">
                                                                    @Localizer["Income_Remove"]
                                                                </button>
                                                            </div>
                                                        </div>
                                                }
                                            </div>
                                        }

                                        <button type="button" class="income-add-sub-btn" @onclick="async () => await AddOtherIncome(item)">
                                            + @Localizer["Income_Employment_AddOtherIncome"]
                                        </button>
                                    </div>

                                </div>
                            </div>
                        }
                    </div>
                }
                <button type="button" class="income-add-main-btn" @onclick="async () => await AddEmployment()">
                    + @Localizer["Income_Employment_AddEmployment"]
                </button>

            </div>

        </div>

</div>
