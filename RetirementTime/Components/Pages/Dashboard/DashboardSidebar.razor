@rendermode InteractiveServer
@using RetirementTime.Resources.Common
@using RetirementTime.Resources.Dashboard

<div class="sidebar">
    <div class="sidebar-header">
        <h2 class="sidebar-brand">@Localizer["Sidebar_Brand"]</h2>
        <span class="sidebar-brand-sub">@Localizer["Sidebar_BrandSub_Dashboard"]</span>
    </div>

    <nav class="sidebar-nav">
        <ul class="sidebar-nav-list">

            <li>
                <button class="nav-item @IsActive("overview") @IsDisabled("overview")" @onclick="@(() => SelectItem("overview"))">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                            <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
                        </svg>
                    </span>
                    <span class="nav-label">@DashboardLocalizer["Sidebar_Overview"]</span>
                </button>
            </li>

            <!-- Dynamic Scenarios -->
            @foreach (var scenario in _scenarios)
            {
                var scenarioKey = $"scenario_{scenario.ScenarioId}";
                var isExpanded = _expandedScenarios.Contains(scenario.ScenarioId);

                <li>
                    <button class="nav-item nav-item-expandable @(isExpanded ? "expanded" : "")" @onclick="@(() => ToggleScenario(scenario.ScenarioId))">
                        <span class="nav-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                            </svg>
                        </span>
                        <span class="nav-label @(scenario.ScenarioId == _activeScenarioId ? "nav-label-active" : "")">@scenario.ScenarioName</span>
                        <span class="nav-chevron">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="6 9 12 15 18 9"/>
                            </svg>
                        </span>
                    </button>
                    @if (isExpanded)
                    {
                        <ul class="nav-submenu">
                            <li>
                                <button class="nav-item nav-item-sub @IsActive($"scenario_{scenario.ScenarioId}_settings")" 
                                        @onclick="@(() => SelectScenarioSettings(scenario.ScenarioId))">
                                    <span class="nav-label">@DashboardLocalizer["Sidebar_ScenarioSettings"]</span>
                                </button>
                            </li>
                            @if (scenario.ScenarioFullyCreated)
                            {
                                var isTemp1Expanded = _expendedIncomeAssets.Contains(scenario.ScenarioId);
                                <li>
                                    <button class="nav-item nav-item-sub nav-item-sub-expandable @(isTemp1Expanded ? "expanded" : "")"
                                            @onclick="@(() => ToggleTemp1(scenario.ScenarioId))">
                                        <span class="nav-label @(_activeScenarioId == scenario.ScenarioId && (_activeView == "income" || _activeView == "spending") ? "nav-label-active" : "")">@DashboardLocalizer["Sidebar_FinancialProfile"]</span>
                                        <span class="nav-chevron">
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <polyline points="6 9 12 15 18 9"/>
                                            </svg>
                                        </span>
                                    </button>
                                    @if (isTemp1Expanded)
                                    {
                                        <ul class="nav-sub-submenu">
                                            <li>
                                                <button class="nav-item nav-item-sub-sub @IsActive($"scenario_{scenario.ScenarioId}_income")"
                                                        @onclick="@(() => Navigation.NavigateTo($"/scenario/{scenario.ScenarioId}/income", forceLoad: false))">
                                                    <span class="nav-label">@DashboardLocalizer["Sidebar_Income"]</span>
                                                </button>
                                            </li>
                                            <li>
                                                <button class="nav-item nav-item-sub-sub @IsActive($"scenario_{scenario.ScenarioId}_spending")"
                                                        @onclick="@(() => Navigation.NavigateTo($"/scenario/{scenario.ScenarioId}/spending", forceLoad: false))">
                                                    <span class="nav-label">@DashboardLocalizer["Sidebar_Spending"]</span>
                                                </button>
                                            </li>
                                        </ul>
                                    }
                                </li>
                            }
                        </ul>
                    }
                </li>
            }

            <!-- New Scenario Button -->
            <li class="sidebar-section-divider"></li>
            <li>
                <button class="nav-item nav-item-new-scenario" @onclick="OnNewScenarioClick">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" y1="5" x2="12" y2="19" />
                            <line x1="5" y1="12" x2="19" y2="12" />
                        </svg>
                    </span>
                    <span class="nav-label">@DashboardLocalizer["Sidebar_NewScenario"]</span>
                </button>
            </li>
            <li class="sidebar-section-divider"></li>


        </ul>
    </nav>

    <div class="sidebar-footer">
        <a href="/api/auth/logout" class="nav-item nav-item-logout">
            <span class="nav-icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                    <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
            </span>
            <span class="nav-label">@DashboardLocalizer["Sidebar_Logout"]</span>
        </a>
    </div>
</div>
