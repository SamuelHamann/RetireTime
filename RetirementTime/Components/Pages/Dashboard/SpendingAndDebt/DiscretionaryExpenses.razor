@page "/scenario/{scenarioId:long}/spending/timeline/{timelineId:long}/discretionary-expenses"
@layout DashboardLayout
@rendermode InteractiveServer
@using RetirementTime.Models.Spending

<div class="intro-step">
    <div class="step-header-animate">
        <h1 class="font-headline text-5xl font-bold text-ne-primary mt-3 mb-2">@Localizer["Spending_Discretionary_Title"]</h1>
        <p class="font-body text-ne-on-surface-variant text-base leading-relaxed">@Localizer["Spending_Discretionary_Subtitle"]</p>
    </div>
    <div class="step-body-animate">
        <div class="bg-ne-surface-low rounded-xl px-8 pb-8 pt-5 shadow-sm">
            <div class="income-section-header">
                <h2 class="assets-section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/>
                        <line x1="12" y1="6" x2="12" y2="8"/><line x1="12" y1="16" x2="12" y2="18"/>
                    </svg>
                    @Localizer["Spending_Discretionary_SectionTitle"]
                </h2>
            </div>

            @if (_isLoading)
            {
                <div class="intro-loading"><p>Loading...</p></div>
            }
            else
            {
                <div class="discretionary-toggle-row">
                    <span class="field-question">@Localizer["Spending_Discretionary_UseGroupedEntry"]</span>
                    <button class="grouped-toggle @(_model.UseGroupedEntry ? "grouped-toggle--active" : "")"
                            @onclick="async () => { _model.UseGroupedEntry = !_model.UseGroupedEntry; await Save(); }">
                        <span class="grouped-toggle__option @(!_model.UseGroupedEntry ? "grouped-toggle__option--selected" : "")">
                            @Localizer["Spending_Discretionary_Detailed"]
                        </span>
                        <span class="grouped-toggle__option @(_model.UseGroupedEntry ? "grouped-toggle__option--selected" : "")">
                            @Localizer["Spending_Discretionary_Grouped"]
                        </span>
                    </button>
                </div>

                @if (_model.UseGroupedEntry)
                {
                    <div class="income-fields-grid">
                        @RenderAmountFrequencyRow("Spending_Discretionary_GroupedAmount", _model.GroupedAmount, _model.GroupedFrequencyId,
                            v => { _model.GroupedAmount = v; }, f => { _model.GroupedFrequencyId = f; })
                    </div>
                }
                else
                {
                <div class="income-fields-grid">
                    @RenderAmountFrequencyRow("Spending_Discretionary_GymMembership", _model.GymMembership, _model.GymMembershipFrequencyId,
                        v => { _model.GymMembership = v; }, f => { _model.GymMembershipFrequencyId = f; })
                    @RenderAmountFrequencyRow("Spending_Discretionary_Subscriptions", _model.Subscriptions, _model.SubscriptionsFrequencyId,
                        v => { _model.Subscriptions = v; }, f => { _model.SubscriptionsFrequencyId = f; })
                    @RenderAmountFrequencyRow("Spending_Discretionary_EatingOut", _model.EatingOut, _model.EatingOutFrequencyId,
                        v => { _model.EatingOut = v; }, f => { _model.EatingOutFrequencyId = f; })
                    @RenderAmountFrequencyRow("Spending_Discretionary_Entertainment", _model.Entertainment, _model.EntertainmentFrequencyId,
                        v => { _model.Entertainment = v; }, f => { _model.EntertainmentFrequencyId = f; })
                    @RenderAmountFrequencyRow("Spending_Discretionary_Travel", _model.Travel, _model.TravelFrequencyId,
                        v => { _model.Travel = v; }, f => { _model.TravelFrequencyId = f; })
                    @RenderAmountFrequencyRow("Spending_Discretionary_CharitableDonations", _model.CharitableDonations, _model.CharitableDonationsFrequencyId,
                        v => { _model.CharitableDonations = v; }, f => { _model.CharitableDonationsFrequencyId = f; })
                    @RenderAmountFrequencyRow("Spending_Discretionary_OtherDiscretionaryExpenses", _model.OtherDiscretionaryExpenses, _model.OtherDiscretionaryExpensesFrequencyId,
                        v => { _model.OtherDiscretionaryExpenses = v; }, f => { _model.OtherDiscretionaryExpensesFrequencyId = f; })
                </div>
                }
            }
        </div>
    </div>
    <div class="income-next-row">
        <button class="income-next-btn" @onclick="NavigateNext">
            <span>@Localizer["Spending_Next"]</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
        </button>
    </div>
</div>

@code {
    private RenderFragment RenderAmountFrequencyRow(string labelKey, decimal? amount, int frequencyId,
        Action<decimal?> onAmountChange, Action<int> onFrequencyChange) =>
        @<div class="spending-field-row">
            <div class="field-group">
                <label class="field-question">@Localizer[labelKey]</label>
                <div class="money-input-wrapper">
                    <input type="number" class="field-input money-input"
                           value="@amount"
                           @onchange="async e => { onAmountChange(e.Value is string s && decimal.TryParse(s, out var v) ? v : null); await Save(); }"
                            />
                </div>
            </div>
            <div class="field-group">
                <label class="field-question">@Localizer["Spending_Field_Frequency"]</label>
                <select class="field-select"
                        value="@frequencyId"
                        @onchange="async e => { if (int.TryParse(e.Value?.ToString(), out var v)) { onFrequencyChange(v); await Save(); } }">
                    @foreach (var f in _frequencies)
                    {
                        <option value="@f.Id">@f.Name</option>
                    }
                </select>
            </div>
        </div>;
}
