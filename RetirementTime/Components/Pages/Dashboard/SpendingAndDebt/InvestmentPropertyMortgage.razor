@page "/scenario/{scenarioId:long}/debt/investment-property-mortgage"
@layout DashboardLayout
@rendermode InteractiveServer

@using RetirementTime.Models.Debt

<div class="intro-step">
    <div class="step-header-animate">
        <h1 class="font-headline text-5xl font-bold text-ne-primary mt-3 mb-2">@Localizer["Debt_InvestmentProperty_Title"]</h1>
        <p class="font-body text-ne-on-surface-variant text-base leading-relaxed">@Localizer["Debt_InvestmentProperty_Subtitle"]</p>
    </div>
    <div class="step-body-animate">
        <div class="bg-ne-surface-low rounded-xl px-8 pb-8 pt-5 shadow-sm">
            <div class="income-section-header">
                <h2 class="assets-section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
                    </svg>
                    @Localizer["Debt_InvestmentProperty_SectionTitle"]
                </h2>
            </div>
            <p class="field-sublabel" style="margin-bottom: 1.25rem;">@Localizer["Debt_InvestmentProperty_Hint"]</p>
            @if (_isLoading)
            {
                <div class="intro-loading"><p>Loading...</p></div>
            }
            else
            {
                @* One form per investment property — name is read-only, lazy-created on first save *@
                @foreach (var property in _properties)
                {
                    var debt = GetLinkedDebt(property.Id);
                    <div class="debt-asset-group">
                        <div class="debt-asset-group-header">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
                            </svg>
                            <span>@(string.IsNullOrWhiteSpace(property.Name) ? Localizer["Debt_InvestmentProperty_DefaultName"].Value : property.Name)</span>
                            @if (property.PropertyValue.HasValue)
                            {
                                <span class="debt-asset-context-value">$@property.PropertyValue.Value.ToString("N0")</span>
                            }
                        </div>
                        <div class="income-fields-grid">
                            <div class="field-group">
                                <label class="field-question">@Localizer["Debt_Field_Balance"]</label>
                                <div class="money-input-wrapper">
                                    <input type="number" class="field-input money-input" @bind="debt.Balance" @bind:after="async () => await SaveLinkedItem(debt)" min="0" step="0.01" />
                                </div>
                            </div>
                            <div class="field-group">
                                <label class="field-question">@Localizer["Debt_Field_InterestRate"]</label>
                                <div class="percent-input-wrapper">
                                    <input type="number" class="field-input percent-input" @bind="debt.InterestRate" @bind:after="async () => await SaveLinkedItem(debt)" min="0" step="0.01" />
                                </div>
                            </div>
                            <div class="field-group">
                                <label class="field-question">@Localizer["Debt_Field_Frequency"]</label>
                                <select class="field-select" @bind="debt.FrequencyId" @bind:after="async () => await SaveLinkedItem(debt)">
                                    @foreach (var f in _frequencies)
                                    {
                                        <option value="@f.Id">@f.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="field-group">
                                <label class="field-question">@Localizer["Debt_Field_TermInYears"]</label>
                                <input type="number" class="field-input" @bind="debt.TermInYears" @bind:after="async () => await SaveLinkedItem(debt)" min="0" max="50" />
                            </div>
                        </div>
                    </div>
                }

                @* Standalone mortgages (sold at a loss etc.) *@
                <div class="debt-asset-group debt-asset-group--standalone">
                    <div class="debt-asset-group-header debt-asset-group-header--standalone">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        <span>@Localizer["Debt_Standalone"]</span>
                    </div>
                    <div class="income-items-list">
                        @foreach (var item in GetStandalone())
                        {
                            var index = GetStandalone().IndexOf(item);
                            @RenderStandaloneCard(item, index)
                        }
                    </div>
                    <button type="button" class="income-add-main-btn" @onclick="AddStandalone">
                        + @Localizer["Debt_InvestmentProperty_AddItem"]
                    </button>
                </div>
            }
        </div>
    </div>
    <div class="income-next-row">
        <button class="income-next-btn" @onclick="NavigateNext">
            <span>@Localizer["Debt_Next"]</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
        </button>
    </div>
</div>

@code {
    private RenderFragment RenderStandaloneCard(GenericDebtItemModel item, int index) =>
        @<div class="income-item-card">
            <div class="income-item-header">
                <span class="income-item-number">@string.Format(Localizer["Debt_InvestmentProperty_Item"].Value, index + 1)</span>
                <button type="button" class="income-remove-btn" @onclick="async () => await RemoveStandalone(item)">@Localizer["Debt_Remove"]</button>
            </div>
            <div class="income-fields-grid">
                <div class="field-group income-field-full">
                    <label class="field-question">@Localizer["Debt_Field_Name"]</label>
                    <input type="text" class="field-input" @bind="item.Name" @bind:after="async () => await SaveStandalone(item)" />
                </div>
                <div class="field-group">
                    <label class="field-question">@Localizer["Debt_Field_Balance"]</label>
                    <div class="money-input-wrapper">
                        <input type="number" class="field-input money-input" @bind="item.Balance" @bind:after="async () => await SaveStandalone(item)" min="0" step="0.01" />
                    </div>
                </div>
                <div class="field-group">
                    <label class="field-question">@Localizer["Debt_Field_InterestRate"]</label>
                    <div class="percent-input-wrapper">
                        <input type="number" class="field-input percent-input" @bind="item.InterestRate" @bind:after="async () => await SaveStandalone(item)" min="0" step="0.01" />
                    </div>
                </div>
                <div class="field-group">
                    <label class="field-question">@Localizer["Debt_Field_Frequency"]</label>
                    <select class="field-select" @bind="item.FrequencyId" @bind:after="async () => await SaveStandalone(item)">
                        @foreach (var f in _frequencies)
                        {
                            <option value="@f.Id">@f.Name</option>
                        }
                    </select>
                </div>
                <div class="field-group">
                    <label class="field-question">@Localizer["Debt_Field_TermInYears"]</label>
                    <input type="number" class="field-input" @bind="item.TermInYears" @bind:after="async () => await SaveStandalone(item)" min="0" max="50" />
                </div>
            </div>
        </div>;
}
