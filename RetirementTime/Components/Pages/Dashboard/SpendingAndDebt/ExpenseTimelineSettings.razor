@page "/scenario/{scenarioId:long}/spending/timeline/{timelineId:long}/settings"
@layout DashboardLayout
@rendermode InteractiveServer

@using RetirementTime.Models.Spending
@using RetirementTime.Resources.Dashboard

<div class="intro-step">
    <div class="step-header-animate">
        <h1 class="font-headline text-5xl font-bold text-ne-primary mt-3 mb-2">@Localizer["ExpenseTimeline_Title"]</h1>
        <p class="font-body text-ne-on-surface-variant text-base leading-relaxed">@Localizer["ExpenseTimeline_Subtitle"]</p>
    </div>

    <div class="step-body-animate">
        @if (_isLoading)
        {
            <div class="intro-loading"><p>Loading...</p></div>
        }
        else
        {
            <div class="bg-ne-surface-low rounded-xl px-8 pb-8 pt-5 shadow-sm">
                <div class="income-fields-grid">

                    <div class="field-group">
                        <label class="field-question">@Localizer["ExpenseTimeline_AgeFrom"]</label>
                        <input type="number" class="field-input" @bind="_model.AgeFrom" min="0" max="120" />
                    </div>

                    <div class="field-group">
                        <label class="field-question">@Localizer["ExpenseTimeline_AgeTo"]</label>
                        <input type="number" class="field-input" @bind="_model.AgeTo" min="0" max="120" />
                    </div>

                    <div class="field-group income-field-full">
                        <label class="field-question">@Localizer["ExpenseTimeline_CloneFrom"]</label>
                        <select class="field-select" @bind="_model.CloneFromId" disabled="@_model.IsFullyCreated">
                            <option value="">@Localizer["ExpenseTimeline_CloneFromNone"]</option>
                            @foreach (var other in _otherTimelines)
                            {
                                <option value="@other.Id">@other.Name (@other.AgeFrom – @other.AgeTo)</option>
                            }
                        </select>
                        @if (_model.IsFullyCreated)
                        {
                            <p class="field-sublabel mt-1">@Localizer["ExpenseTimeline_CloneFromLocked"]</p>
                        }
                    </div>

                </div>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="alert-error mt-4">@_errorMessage</div>
                }

                <div class="intro-actions mt-6" style="display:flex; gap:1rem;">
                    <button class="btn-primary-action" @onclick="Save" disabled="@_isSaving">
                        @(_isSaving ? Localizer["ExpenseTimeline_Saving"] : Localizer["ExpenseTimeline_Save"])
                    </button>
                    <button class="btn-danger" @onclick="Delete" disabled="@_isDeleting">
                        @Localizer["ExpenseTimeline_Delete"]
                    </button>
                </div>
            </div>
        }
    </div>
</div>

