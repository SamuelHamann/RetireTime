@page "/scenario/{scenarioId:long}/debt/credit-cards"
@layout DashboardLayout
@rendermode InteractiveServer

@using RetirementTime.Models.Debt

<div class="intro-step">
    <div class="step-header-animate">
        <h1 class="font-headline text-5xl font-bold text-ne-primary mt-3 mb-2">@Localizer["Debt_CreditCards_Title"]</h1>
        <p class="font-body text-ne-on-surface-variant text-base leading-relaxed">@Localizer["Debt_CreditCards_Subtitle"]</p>
    </div>
    <div class="step-body-animate">
        <div class="bg-ne-surface-low rounded-xl px-8 pb-8 pt-5 shadow-sm">
            <div class="income-section-header">
                <h2 class="assets-section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>
                    </svg>
                    @Localizer["Debt_CreditCards_SectionTitle"]
                </h2>
            </div>
            <p class="field-sublabel" style="margin-bottom: 1.25rem;">@Localizer["Debt_CreditCards_Hint"]</p>
            @if (_isLoading)
            {
                <div class="intro-loading"><p>Loading...</p></div>
            }
            else
            {
                <div class="income-items-list">
                    @foreach (var item in _items)
                    {
                        var index = _items.IndexOf(item);
                        <div class="income-item-card">
                            <div class="income-item-header">
                                <span class="income-item-number">@string.Format(Localizer["Debt_CreditCards_Item"].Value, index + 1)</span>
                                <button type="button" class="income-remove-btn" @onclick="async () => await RemoveItem(item)">@Localizer["Debt_Remove"]</button>
                            </div>
                            <div class="income-fields-grid">
                                <div class="field-group income-field-full">
                                    <label class="field-question">@Localizer["Debt_Field_Name"]</label>
                                    <input type="text" class="field-input" @bind="item.Name" @bind:after="async () => await SaveItem(item)" />
                                </div>
                                <div class="field-group">
                                    <label class="field-question">@Localizer["Debt_Field_Balance"]</label>
                                    <div class="money-input-wrapper">
                                        <input type="number" class="field-input money-input" @bind="item.Balance" @bind:after="async () => await SaveItem(item)" min="0" step="0.01" />
                                    </div>
                                </div>
                                <div class="field-group">
                                    <label class="field-question">@Localizer["Debt_Field_InterestRate"]</label>
                                    <div class="percent-input-wrapper">
                                        <input type="number" class="field-input percent-input" @bind="item.InterestRate" @bind:after="async () => await SaveItem(item)" min="0" step="0.01" />
                                    </div>
                                </div>
                                <div class="field-group">
                                    <label class="field-question">@Localizer["Debt_Field_Frequency"]</label>
                                    <select class="field-select" @bind="item.FrequencyId" @bind:after="async () => await SaveItem(item)">
                                        @foreach (var f in _frequencies)
                                        {
                                            <option value="@f.Id">@f.Name</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <button type="button" class="income-add-main-btn" @onclick="async () => await AddItem()">
                    + @Localizer["Debt_CreditCards_AddItem"]
                </button>
            }
        </div>
    </div>
</div>
