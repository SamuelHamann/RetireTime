@page "/scenario/{scenarioId:long}/spending/timeline/{timelineId:long}/assets-expenses"
@layout DashboardLayout
@rendermode InteractiveServer
@using RetirementTime.Models.Spending

<div class="intro-step">
    <div class="step-header-animate">
        <h1 class="font-headline text-5xl font-bold text-ne-primary mt-3 mb-2">@Localizer["Spending_AssetsExpenses_Title"]</h1>
        <p class="font-body text-ne-on-surface-variant text-base leading-relaxed">@Localizer["Spending_AssetsExpenses_Subtitle"]</p>
    </div>
    <div class="step-body-animate">
        <div class="bg-ne-surface-low rounded-xl px-8 pb-8 pt-5 shadow-sm">
            <div class="income-section-header">
                <h2 class="assets-section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
                    </svg>
                    @Localizer["Spending_AssetsExpenses_SectionTitle"]
                </h2>
            </div>
            <p class="field-sublabel" style="margin-bottom: 1.25rem;">@Localizer["Spending_AssetsExpenses_Hint"]</p>

            @if (_isLoading)
            {
                <div class="intro-loading"><p>Loading...</p></div>
            }
            else
            {
                @* One row per linked asset *@
                @foreach (var item in _linkedItems)
                {
                    <div class="debt-asset-group">
                        <div class="debt-asset-group-header">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                            </svg>
                            <span>@(string.IsNullOrWhiteSpace(item.Name) ? Localizer["Spending_AssetsExpenses_DefaultName"].Value : item.Name)</span>
                        </div>
                        <div class="income-fields-grid">
                            <div class="field-group">
                                <label class="field-question">@Localizer["Spending_Field_Expense"]</label>
                                <div class="money-input-wrapper">
                                    <input type="number" class="field-input money-input" @bind="item.Expense" @bind:after="async () => await SaveLinked(item)" min="0" step="0.01" />
                                </div>
                            </div>
                            <div class="field-group">
                                <label class="field-question">@Localizer["Spending_Field_Frequency"]</label>
                                <select class="field-select" @bind="item.FrequencyId" @bind:after="async () => await SaveLinked(item)">
                                    @foreach (var f in _frequencies)
                                    {
                                        <option value="@f.Id">@f.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                }

                @* Standalone expenses *@
                <div class="debt-asset-group debt-asset-group--standalone">
                    <div class="debt-asset-group-header debt-asset-group-header--standalone">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        <span>@Localizer["Debt_Standalone"]</span>
                    </div>
                    <div class="income-items-list">
                        @foreach (var item in _standaloneItems)
                        {
                            var index = _standaloneItems.IndexOf(item);
                            @RenderStandaloneCard(item, index)
                        }
                    </div>
                    <button type="button" class="income-add-main-btn" @onclick="AddStandalone">
                        + @Localizer["Spending_AssetsExpenses_AddItem"]
                    </button>
                </div>
            }
        </div>
    </div>
    <div class="income-next-row">
        <button class="income-next-btn" @onclick="NavigateNext">
            <span>@Localizer["Spending_Next"]</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
        </button>
    </div>
</div>

@code {
    private RenderFragment RenderStandaloneCard(SpendingAssetsExpenseItemModel item, int index) =>
        @<div class="income-item-card">
            <div class="income-item-header">
                <span class="income-item-number">@string.Format(Localizer["Spending_AssetsExpenses_Item"].Value, index + 1)</span>
                <button type="button" class="income-remove-btn" @onclick="async () => await RemoveStandalone(item)">@Localizer["Spending_Remove"]</button>
            </div>
            <div class="income-fields-grid">
                <div class="field-group income-field-full">
                    <label class="field-question">@Localizer["Spending_Field_Name"]</label>
                    <input type="text" class="field-input" @bind="item.Name" @bind:after="async () => await SaveStandalone(item)" />
                </div>
                <div class="field-group">
                    <label class="field-question">@Localizer["Spending_Field_Expense"]</label>
                    <div class="money-input-wrapper">
                        <input type="number" class="field-input money-input" @bind="item.Expense" @bind:after="async () => await SaveStandalone(item)" min="0" step="0.01" />
                    </div>
                </div>
                <div class="field-group">
                    <label class="field-question">@Localizer["Spending_Field_Frequency"]</label>
                    <select class="field-select" @bind="item.FrequencyId" @bind:after="async () => await SaveStandalone(item)">
                        @foreach (var f in _frequencies)
                        {
                            <option value="@f.Id">@f.Name</option>
                        }
                    </select>
                </div>
            </div>
        </div>;
}
