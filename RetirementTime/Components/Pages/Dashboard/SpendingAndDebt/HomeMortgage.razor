@page "/scenario/{scenarioId:long}/debt/home-mortgage"
@layout DashboardLayout
@rendermode InteractiveServer

<div class="intro-step">
    <div class="step-header-animate">
        <h1 class="font-headline text-5xl font-bold text-ne-primary mt-3 mb-2">@Localizer["Debt_HomeMortgage_Title"]</h1>
        <p class="font-body text-ne-on-surface-variant text-base leading-relaxed">@Localizer["Debt_HomeMortgage_Subtitle"]</p>
    </div>
    <div class="step-body-animate">
        <div class="bg-ne-surface-low rounded-xl px-8 pb-8 pt-5 shadow-sm">
            <div class="income-section-header">
                <h2 class="assets-section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                    @Localizer["Debt_HomeMortgage_SectionTitle"]
                </h2>
            </div>

            @if (_isLoading)
            {
                <div class="intro-loading"><p>Loading...</p></div>
            }
            else
            {
                @if (_homeAsset != null)
                {
                    <div class="debt-asset-context">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
                        </svg>
                        <span>@Localizer["Debt_LinkedAsset"] <strong>@Localizer["Debt_PrimaryResidence"]</strong></span>
                        @if (_homeAsset.HomeValue.HasValue)
                        {
                            <span class="debt-asset-context-value">$@_homeAsset.HomeValue.Value.ToString("N0")</span>
                        }
                    </div>
                }
                <div class="income-fields-grid">
                    <div class="field-group">
                        <label class="field-question">@Localizer["Debt_HomeMortgage_Principal"]</label>
                        <div class="money-input-wrapper">
                            <input type="number" class="field-input money-input" @bind="_model.Balance" @bind:after="Save" min="0" step="0.01" />
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="field-question">@Localizer["Debt_HomeMortgage_InterestRate"]</label>
                        <div class="percent-input-wrapper">
                            <input type="number" class="field-input percent-input" @bind="_model.InterestRate" @bind:after="Save" min="0" step="0.01" />
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="field-question">@Localizer["Debt_HomeMortgage_Frequency"]</label>
                        <select class="field-select" @bind="_model.FrequencyId" @bind:after="Save">
                            @foreach (var f in _frequencies)
                            {
                                <option value="@f.Id">@f.Name</option>
                            }
                        </select>
                    </div>
                    <div class="field-group">
                        <label class="field-question">@Localizer["Debt_HomeMortgage_TermInYears"]</label>
                        <input type="number" class="field-input" @bind="_model.TermInYears" @bind:after="Save" min="0" max="50" />
                    </div>
                </div>
            }
        </div>
    </div>
    <div class="income-next-row">
        <button class="income-next-btn" @onclick="NavigateNext">
            <span>@Localizer["Debt_Next"]</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
        </button>
    </div>
</div>
